---
interface Props {
  current?: string;
}

const { current = 'home' } = Astro.props;

const links = [
  { id: 'home', href: '/', label: '🏠 홈', isTab: true },
  { id: 'work', href: '/work', label: '💼 업무', isTab: false },
  { id: 'stats', href: '/stats', label: '🤝 싱크', isTab: false },
  { id: 'weather', href: '/weather', label: '🌤️ 날씨', isTab: false },
];
---

<nav class="nav">
  {current !== 'home' && (
    <a href="/" class="nav-back">← HOME</a>
  )}
  <div class="nav-links">
    {links.filter(l => l.id !== current).map(l => (
      <a href={l.href} class="nav-link">{l.label}</a>
    ))}
  </div>
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .nav-back {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    text-decoration: none;
    padding: 0.4rem 0.8rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    transition: all 0.2s;
    font-weight: 600;
  }
  .nav-back:hover { color: var(--purple); border-color: var(--purple); }
  .nav-links { display: flex; gap: 0.3rem; flex-wrap: wrap; }
  .nav-link {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--text-dim);
    text-decoration: none;
    padding: 0.4rem 0.8rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    transition: all 0.2s;
  }
  .nav-link:hover { color: var(--purple); border-color: var(--purple); background: rgba(124,92,252,0.04); }
</style>
