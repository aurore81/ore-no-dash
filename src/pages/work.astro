const PAGE_SIZE = 15;
let currentPage = 0;
let currentProject = 'all';

function init() {
  renderStoryCards();
  renderTabs();
  selectProject('all');
  updateClock();
  setInterval(updateClock, 1000);
}

function updateClock() {
  document.getElementById('nav-time').textContent =
    new Date().toLocaleString('ko-KR', { year:'numeric',month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false });
}

function getAllCommits() {
  return projects.filter(p => p.commits).flatMap(p =>
    p.commits.map(c => ({ ...c, project: p.id, projectColor: p.color }))
  );
}

function renderStoryCards() {
  const all = getAllCommits();
  const projsWithCommits = projects.filter(p => p.commits);
  const activeProjCount = projsWithCommits.filter(p => p.status === 'active').length;
  const dates = [...new Set(all.map(c => c.date))].sort();
  const recentDate = dates[dates.length - 1];
  const recentCount = all.filter(c => c.date === recentDate).length;
  const feats = all.filter(c => c.type === 'feat').length;
  const fixes = all.filter(c => c.type === 'fix').length;

  // Find busiest day
  const dayCounts = {};
  all.forEach(c => { dayCounts[c.date] = (dayCounts[c.date] || 0) + 1; });
  const busiest = Object.entries(dayCounts).sort((a,b) => b[1] - a[1])[0];

  // Work span
  const firstDate = dates[0];
  const daySpan = Math.ceil((new Date(recentDate) - new Date(firstDate)) / 86400000) + 1;

  const stories = [
    {
      emoji: '🚀', value: activeProjCount + '/' + projsWithCommits.length,
      title: '활성 프로젝트', color: 'var(--green)',
      tip: '현재 활발히 개발 중인 프로젝트 수 / 전체 프로젝트 수. active 상태만 카운트.'
    },
    {
      emoji: '📝', value: all.length,
      title: '전체 커밋', color: 'var(--purple)',
      tip: '모든 프로젝트를 합산한 총 커밋 수. 하나의 커밋 = 하나의 의미있는 코드 변경 단위.'
    },
    {
      emoji: '✨', value: feats,
      title: '새 기능 출시', color: 'var(--orange)',
      tip: 'feat 타입 커밋. 사용자가 실제로 체감하는 새 기능이 추가된 횟수.'
    },
    {
      emoji: '🔧', value: fixes,
      title: '버그 수정', color: 'var(--blue)',
      tip: 'fix 타입 커밋. 발견된 버그나 이슈를 고친 횟수. 안정성의 척도.'
    },
    {
      emoji: '🔥', value: busiest[1] + '개',
      title: formatDate(busiest[0]) + ' 폭풍코딩',
      color: 'var(--pink)',
      tip: '가장 많은 커밋을 한 날. 하루에 ' + busiest[1] + '개의 변경을 밀어넣은 날!'
    },
    {
      emoji: '📅', value: daySpan + '일',
      title: '작업 기간', color: 'var(--cyan)',
      tip: firstDate + ' ~ ' + recentDate + '. 첫 커밋부터 마지막 커밋까지의 총 일수.'
    },
  ];

  const el = document.getElementById('story-row');
  stories.forEach(s => {
    const card = document.createElement('div');
    card.className = 'story-card';
    card.innerHTML = `
      <div class="accent-bar" style="background:${s.color}"></div>
      <span class="story-emoji">${s.emoji}</span>
      <div class="story-value">${s.value}</div>
      <div class="story-title">${s.title}</div>
      <div class="story-tip">${s.tip}</div>
    `;
    el.appendChild(card);
  });
}

function renderTabs() {
  const el = document.getElementById('project-tabs');
  projects.forEach(p => {
    const btn = document.createElement('button');
    btn.className = 'proj-tab';
    btn.dataset.id = p.id;
    const count = p.commits ? p.commits.length : getAllCommits().length;
    btn.innerHTML = `${p.icon} ${p.name} <span class="count">${count}</span>`;
    btn.addEventListener('click', () => selectProject(p.id));
    el.appendChild(btn);
  });
}

function selectProject(id) {
  currentProject = id;
  currentPage = 0;
  document.querySelectorAll('.proj-tab').forEach(t => {
    t.classList.toggle('active', t.dataset.id === id);
  });
  renderProjectInfo(id);
  renderTimeline();
}

function renderProjectInfo(id) {
  const panelsEl = document.getElementById('project-panels');
  panelsEl.innerHTML = '';
  if (id === 'all') return;

  const p = projects.find(pr => pr.id === id);
  if (!p) return;

  const panel = document.createElement('div');
  panel.className = 'project-info active';
  panel.innerHTML = `
    <div class="proj-icon">${p.icon}</div>
    <div class="proj-details">
      <div class="proj-name">${p.name}</div>
      <div class="proj-desc">${p.desc}</div>
      <div class="proj-meta">
        <span class="proj-meta-tag">${p.tech}</span>
        <span class="proj-meta-tag">${p.repo}</span>
        <span class="proj-meta-tag">${p.commits ? p.commits.length : 0} commits</span>
        <span class="proj-status status-${p.status}">${p.status}</span>
      </div>
    </div>
  `;
  panelsEl.appendChild(panel);
}

function getFilteredCommits() {
  if (currentProject === 'all') {
    return getAllCommits().sort((a, b) => b.date.localeCompare(a.date));
  }
  const p = projects.find(pr => pr.id === currentProject);
  return p && p.commits ? p.commits.map(c => ({ ...c, project: p.id, projectColor: p.color })) : [];
}

function renderTimeline() {
  const el = document.getElementById('timeline');
  el.innerHTML = '';

  const commits = getFilteredCommits();
  const totalPages = Math.ceil(commits.length / PAGE_SIZE);
  const start = currentPage * PAGE_SIZE;
  const slice = commits.slice(start, start + PAGE_SIZE);

  // Update title
  const title = document.getElementById('timeline-title');
  title.textContent = `📜 타임라인 (${commits.length}건)`;

  // Group by date
  const grouped = {};
  slice.forEach(c => {
    if (!grouped[c.date]) grouped[c.date] = [];
    grouped[c.date].push(c);
  });

  Object.keys(grouped).sort((a, b) => b.localeCompare(a)).forEach(date => {
    const dayEl = document.createElement('div');
    dayEl.className = 'tl-day';
    dayEl.innerHTML = `<div class="tl-date">${formatDate(date)} <span class="day-count">${grouped[date].length}건</span></div>`;

    grouped[date].forEach(c => {
      const item = document.createElement('div');
      item.className = 'tl-item';
      const projTag = (currentProject === 'all' && c.project)
        ? `<span class="tl-proj-tag" style="background:${c.projectColor}15;color:${c.projectColor}">${c.project}</span>`
        : '';
      item.innerHTML = `
        <span class="tl-badge ${c.type}">${c.type}</span>
        <span class="tl-msg">${c.msg}${projTag}</span>
        <span class="tl-hash">${c.hash}</span>
      `;
      dayEl.appendChild(item);
    });

    el.appendChild(dayEl);
  });

  renderPaging(totalPages);
}

function renderPaging(totalPages) {
  const el = document.getElementById('paging');
  el.innerHTML = '';
  if (totalPages <= 1) return;

  // Prev button
  const prev = document.createElement('button');
  prev.className = 'page-btn';
  prev.textContent = '← 이전';
  prev.disabled = currentPage === 0;
  prev.addEventListener('click', () => { currentPage--; renderTimeline(); scrollToTimeline(); });
  el.appendChild(prev);

  // Page dots
  const dots = document.createElement('div');
  dots.className = 'page-dots';
  for (let i = 0; i < totalPages; i++) {
    const dot = document.createElement('div');
    dot.className = 'page-dot' + (i === currentPage ? ' active' : '');
    dot.addEventListener('click', () => { currentPage = i; renderTimeline(); scrollToTimeline(); });
    dots.appendChild(dot);
  }
  el.appendChild(dots);

  // Page info
  const info = document.createElement('span');
  info.className = 'page-info';
  info.textContent = `${currentPage + 1} / ${totalPages}`;
  el.appendChild(info);

  // Next button
  const next = document.createElement('button');
  next.className = 'page-btn';
  next.textContent = '다음 →';
  next.disabled = currentPage === totalPages - 1;
  next.addEventListener('click', () => { currentPage++; renderTimeline(); scrollToTimeline(); });
  el.appendChild(next);
}

function scrollToTimeline() {
  document.getElementById('timeline-title').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function formatDate(dateStr) {
  const d = new Date(dateStr);
  const days = ['일', '월', '화', '수', '목', '금', '토'];
  return `${d.getMonth() + 1}/${d.getDate()} (${days[d.getDay()]})`;
}

init();
</script>
