  const PAGE_SIZE = 15;
  let currentPage = 0;
  let currentProject = 'all';

  // --- Helpers ---
  function getAllCommits() {
    return projects.filter(p => p.id !== 'all' && p.commits.length > 0)
      .flatMap(p => p.commits.map(c => ({ ...c, project: p.id, projectColor: p.color })));
  }

  function formatDate(dateStr: string): string {
    const d = new Date(dateStr);
    const days = ['일', '월', '화', '수', '목', '금', '토'];
    return `${d.getMonth() + 1}/${d.getDate()} (${days[d.getDay()]})`;
  }

  const badgeColors: Record<string, string> = {
    feat: 'bg-green/15 text-green',
    fix: 'bg-blue/15 text-blue',
    docs: 'bg-purple/15 text-purple',
    merge: 'bg-yellow/15 text-yellow',
    refactor: 'bg-pink/15 text-pink',
    init: 'bg-cyan/15 text-cyan',
  };

  const statusStyles: Record<string, { bg: string; text: string }> = {
    active: { bg: 'bg-green/10', text: 'text-green' },
    staging: { bg: 'bg-yellow/10', text: 'text-yellow' },
    init: { bg: 'bg-blue/10', text: 'text-blue' },
    archive: { bg: 'bg-dim/10', text: 'text-dim' },
  };

  // --- Render stats ---
  function renderStats() {
    const el = document.getElementById('stats-row');
    if (!el) return;

    const all = getAllCommits();
    const filtered = currentProject === 'all' ? all : all.filter(c => c.project === currentProject);
    const feats = filtered.filter(c => c.type === 'feat').length;
    const fixes = filtered.filter(c => c.type === 'fix').length;
    const dates = [...new Set(filtered.map(c => c.date))];

    const items = [
      { value: filtered.length.toString(), label: '커밋', color: 'text-accent' },
      { value: feats.toString(), label: '기능', color: 'text-green' },
      { value: fixes.toString(), label: '수정', color: 'text-blue' },
      { value: dates.length + '일', label: '활동일', color: 'text-orange' },
    ];

    el.innerHTML = items.map(s => `
      <div class="bg-card border border-border rounded-2xl p-5 text-center">
        <div class="text-3xl font-black ${s.color}">${s.value}</div>
        <div class="text-xs font-bold text-dim mt-1">${s.label}</div>
      </div>
    `).join('');
  }

  // --- Render tabs ---
  function renderTabs() {
    const el = document.getElementById('project-tabs');
    if (!el) return;
    el.innerHTML = '';

    projects.forEach(p => {
      const count = p.id === 'all' ? getAllCommits().length : p.commits.length;
      const btn = document.createElement('button');
      btn.className = 'proj-tab' + (p.id === currentProject ? ' active' : '');
      btn.innerHTML = `${p.icon} ${p.name} <span class="font-mono text-[0.7rem] opacity-60 ml-0.5">${count}</span>`;
      btn.addEventListener('click', () => selectProject(p.id));
      el.appendChild(btn);
    });
  }

  // --- Select project ---
  function selectProject(id: string) {
    currentProject = id;
    currentPage = 0;
    renderTabs();
    renderProjectInfo();
    renderStats();
    renderTimeline();
  }

  // --- Project info panel ---
  function renderProjectInfo() {
    const el = document.getElementById('project-info');
    if (!el) return;

    if (currentProject === 'all') { el.innerHTML = ''; return; }

    const p = projects.find(pr => pr.id === currentProject);
    if (!p) return;

    const st = statusStyles[p.status] || statusStyles.archive;

    el.innerHTML = `
      <div class="bg-card border border-border rounded-2xl p-6 mb-6 flex items-center gap-5 flex-wrap">
        <div class="text-5xl">${p.icon}</div>
        <div class="flex-1 min-w-[200px]">
          <div class="text-xl font-black text-text">${p.name}</div>
          <div class="text-sm text-sub mt-0.5">${p.desc}</div>
          <div class="flex gap-2 mt-2 flex-wrap">
            <span class="text-xs font-mono px-2.5 py-1 rounded-lg bg-bg text-dim">${p.tech}</span>
            <span class="text-xs font-mono px-2.5 py-1 rounded-lg bg-bg text-dim">${p.repo}</span>
            <span class="text-xs font-extrabold px-2.5 py-1 rounded-lg ${st.bg} ${st.text} uppercase">${p.status}</span>
          </div>
        </div>
      </div>
    `;
  }

  // --- Timeline ---
  function getFilteredCommits() {
    if (currentProject === 'all') {
      return getAllCommits().sort((a, b) => b.date.localeCompare(a.date));
    }
    const p = projects.find(pr => pr.id === currentProject);
    return p ? p.commits.map(c => ({ ...c, project: p.id, projectColor: p.color })) : [];
  }

  function renderTimeline() {
    const el = document.getElementById('timeline');
    if (!el) return;
    el.innerHTML = '';

    const commits = getFilteredCommits();
    const totalPages = Math.ceil(commits.length / PAGE_SIZE);
    const start = currentPage * PAGE_SIZE;
    const slice = commits.slice(start, start + PAGE_SIZE);

    const titleEl = document.getElementById('tl-title');
    if (titleEl) titleEl.textContent = `타임라인 (${commits.length}건)`;

    // Group by date
    const grouped: Record<string, any[]> = {};
    slice.forEach(c => {
      if (!grouped[c.date]) grouped[c.date] = [];
      grouped[c.date].push(c);
    });

    Object.keys(grouped).sort((a, b) => b.localeCompare(a)).forEach(date => {
      const dayEl = document.createElement('div');
      dayEl.className = 'mb-5';

      dayEl.innerHTML = `
        <div class="text-sm font-black text-accent mb-2 pl-3 border-l-3 border-accent">
          ${formatDate(date)}
          <span class="text-xs font-mono text-dim ml-2">${grouped[date].length}건</span>
        </div>
      `;

      grouped[date].forEach(c => {
        const badge = badgeColors[c.type] || 'bg-dim/15 text-dim';
        const projTag = currentProject === 'all'
          ? `<span class="text-[0.6rem] font-mono font-bold px-1.5 py-0.5 rounded ml-2" style="background:${c.projectColor}15;color:${c.projectColor}">${c.project}</span>`
          : '';

        const item = document.createElement('div');
        item.className = 'bg-card border border-border rounded-xl px-4 py-3 mb-2 flex items-start gap-3 hover:border-accent/20 transition-all hover:translate-x-1';
        item.innerHTML = `
          <span class="text-[0.65rem] font-extrabold px-2 py-0.5 rounded-full ${badge} shrink-0 mt-0.5 uppercase">${c.type}</span>
          <span class="text-sm text-sub flex-1">${c.msg}${projTag}</span>
          <span class="text-xs font-mono text-dim shrink-0">${c.hash}</span>
        `;
        dayEl.appendChild(item);
      });

      el.appendChild(dayEl);
    });

    renderPaging(totalPages);
  }

  // --- Pagination ---
  function renderPaging(totalPages: number) {
    const el = document.getElementById('paging');
    if (!el) return;
    el.innerHTML = '';
    if (totalPages <= 1) return;

    const prev = document.createElement('button');
    prev.className = 'px-4 py-2 rounded-xl bg-card border border-border text-sm font-bold text-sub hover:text-accent hover:border-accent transition-all disabled:opacity-30 disabled:cursor-not-allowed';
    prev.textContent = '← 이전';
    prev.disabled = currentPage === 0;
    prev.addEventListener('click', () => { currentPage--; renderTimeline(); scrollToTl(); });
    el.appendChild(prev);

    const info = document.createElement('span');
    info.className = 'text-sm font-mono text-dim px-3 py-2';
    info.textContent = `${currentPage + 1} / ${totalPages}`;
    el.appendChild(info);

    const next = document.createElement('button');
    next.className = 'px-4 py-2 rounded-xl bg-card border border-border text-sm font-bold text-sub hover:text-accent hover:border-accent transition-all disabled:opacity-30 disabled:cursor-not-allowed';
    next.textContent = '다음 →';
    next.disabled = currentPage === totalPages - 1;
    next.addEventListener('click', () => { currentPage++; renderTimeline(); scrollToTl(); });
    el.appendChild(next);
  }

  function scrollToTl() {
    document.getElementById('tl-title')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // --- Init ---
  renderTabs();
  selectProject('all');
</script>
