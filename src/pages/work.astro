<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>WORK LOG // aurore.work</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=JetBrains+Mono:wght@400;600;700&family=Noto+Sans+KR:wght@400;700;900&display=swap');

    :root {
      --bg: #f8f9fc;
      --bg2: #eef0f6;
      --card: #ffffff;
      --card-hover: #fafaff;
      --border: #e0e4ee;
      --text: #1e1e2e;
      --text-sub: #555568;
      --text-dim: #999aaa;
      --purple: #7c5cfc;
      --pink: #ff6b9d;
      --blue: #4a9eff;
      --green: #2ecf7a;
      --orange: #ff8c42;
      --yellow: #ffc107;
      --red: #ff5252;
      --cyan: #00c4b4;
      --gold: #ff9900;
      --shadow: 0 2px 12px rgba(124,92,252,0.06);
      --shadow-hover: 0 8px 24px rgba(124,92,252,0.10);
      --mono: 'JetBrains Mono', monospace;
      --body: 'Nunito', 'Noto Sans KR', sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--body); background: var(--bg); color: var(--text); min-height: 100vh; }

    .container { max-width: 1100px; margin: 0 auto; padding: 1.5rem; }

    /* NAV */
    .nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
    .nav-back {
      font-family: var(--mono); font-size: 0.75rem; color: var(--text-dim);
      text-decoration: none; padding: 0.4rem 0.8rem; border-radius: 10px;
      border: 1px solid var(--border); transition: all 0.2s; font-weight: 600;
    }
    .nav-back:hover { color: var(--purple); border-color: var(--purple); background: rgba(124,92,252,0.04); }
    .nav-time { font-family: var(--mono); font-size: 0.7rem; color: var(--text-dim); }

    /* HEADER */
    .header { text-align: center; margin-bottom: 2rem; }
    .header-emoji { font-size: 3.5rem; display: block; margin-bottom: 0.3rem; }
    .header h1 {
      font-size: 2rem; font-weight: 900;
      background: linear-gradient(135deg, var(--purple), var(--pink), var(--orange));
      background-size: 200% 200%; animation: grad 4s ease infinite;
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    @keyframes grad { 0%,100%{background-position:0% 50%} 50%{background-position:100% 50%} }
    .header-sub { font-size: 0.85rem; color: var(--text-dim); font-weight: 700; margin-top: 0.2rem; }

    /* STORY CARDS - meaningful narrative */
    .story-row {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem; margin-bottom: 2rem;
    }
    .story-card {
      background: var(--card); border: 1px solid var(--border); border-radius: 16px;
      padding: 1.2rem; box-shadow: var(--shadow); transition: all 0.2s;
      position: relative; overflow: hidden; cursor: default;
    }
    .story-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-hover); }
    .story-card .accent-bar {
      position: absolute; top: 0; left: 0; right: 0; height: 3px; border-radius: 16px 16px 0 0;
    }
    .story-emoji { font-size: 1.8rem; margin-bottom: 0.4rem; display: block; }
    .story-value { font-size: 1.6rem; font-weight: 900; color: var(--text); }
    .story-title { font-size: 0.78rem; font-weight: 700; color: var(--text-sub); margin-top: 0.1rem; }
    .story-tip {
      font-size: 0.68rem; color: var(--text-dim); margin-top: 0.4rem; line-height: 1.4;
      padding-top: 0.4rem; border-top: 1px dashed var(--border);
    }

    /* PROJECT TABS */
    .project-tabs {
      display: flex; gap: 0.4rem; margin-bottom: 1.5rem; flex-wrap: wrap;
      justify-content: center;
    }
    .proj-tab {
      background: var(--bg2); border: 1px solid var(--border); border-radius: 20px;
      color: var(--text-dim); padding: 0.45rem 1rem;
      cursor: pointer; font-size: 0.78rem; font-weight: 700;
      transition: all 0.2s; font-family: var(--body);
    }
    .proj-tab:hover { color: var(--purple); border-color: var(--purple); background: rgba(124,92,252,0.04); }
    .proj-tab.active {
      background: var(--purple); color: white; border-color: var(--purple);
      box-shadow: 0 2px 10px rgba(124,92,252,0.25);
    }
    .proj-tab .count { font-family: var(--mono); font-size: 0.65rem; opacity: 0.7; margin-left: 0.2rem; }

    /* PROJECT INFO */
    .project-info {
      background: var(--card); border: 1px solid var(--border); border-radius: 16px;
      padding: 1.2rem 1.5rem; margin-bottom: 1.5rem; box-shadow: var(--shadow);
      display: none; animation: fadeIn 0.3s ease;
    }
    .project-info.active { display: flex; align-items: center; gap: 1.2rem; flex-wrap: wrap; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }
    .proj-icon { font-size: 2.5rem; }
    .proj-details { flex: 1; min-width: 200px; }
    .proj-name { font-size: 1.1rem; font-weight: 900; color: var(--text); }
    .proj-desc { font-size: 0.8rem; color: var(--text-sub); margin-top: 0.15rem; }
    .proj-meta { display: flex; gap: 0.8rem; margin-top: 0.5rem; flex-wrap: wrap; }
    .proj-meta-tag {
      font-family: var(--mono); font-size: 0.65rem; padding: 0.2rem 0.6rem;
      border-radius: 8px; background: var(--bg2); color: var(--text-dim); font-weight: 600;
    }
    .proj-status {
      font-size: 0.65rem; font-weight: 800; padding: 0.2rem 0.6rem;
      border-radius: 8px; text-transform: uppercase;
    }
    .status-active { background: rgba(46,207,122,0.1); color: var(--green); }
    .status-staging { background: rgba(255,193,7,0.1); color: #d68910; }
    .status-init { background: rgba(74,158,255,0.1); color: var(--blue); }
    .status-archive { background: rgba(153,154,170,0.1); color: var(--text-dim); }

    /* SECTION TITLE */
    .section-title {
      font-size: 1rem; font-weight: 800; color: var(--text);
      margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;
    }

    /* TIMELINE */
    .timeline { position: relative; padding-left: 1.2rem; }
    .timeline::before {
      content: ''; position: absolute; left: 4px; top: 0; bottom: 0;
      width: 2px; background: linear-gradient(180deg, var(--purple), var(--pink), var(--orange));
      border-radius: 2px; opacity: 0.2;
    }

    .tl-day { margin-bottom: 1rem; }
    .tl-date {
      font-family: var(--mono); font-size: 0.75rem; font-weight: 700;
      color: var(--purple); margin-bottom: 0.3rem; position: relative;
    }
    .tl-date::before {
      content: ''; position: absolute; left: -1.2rem; top: 50%;
      width: 10px; height: 10px; border-radius: 50%; transform: translate(-1px, -50%);
      background: white; border: 2.5px solid var(--purple);
      box-shadow: 0 0 0 3px rgba(124,92,252,0.12);
    }
    .tl-date .day-count {
      font-size: 0.6rem; background: rgba(124,92,252,0.08); color: var(--purple);
      padding: 0.1rem 0.4rem; border-radius: 8px; margin-left: 0.4rem; font-weight: 600;
    }

    .tl-item {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 10px; padding: 0.5rem 0.8rem; margin-bottom: 0.3rem;
      display: flex; align-items: flex-start; gap: 0.5rem;
      transition: all 0.15s; cursor: default;
    }
    .tl-item:hover {
      background: var(--card-hover); border-color: rgba(124,92,252,0.2);
      transform: translateX(3px); box-shadow: var(--shadow);
    }

    .tl-badge {
      font-family: var(--mono); font-size: 0.55rem; font-weight: 700;
      padding: 0.12rem 0.4rem; border-radius: 6px;
      text-transform: uppercase; white-space: nowrap; flex-shrink: 0; margin-top: 0.12rem;
    }
    .tl-badge.feat { background: rgba(46,207,122,0.12); color: var(--green); }
    .tl-badge.fix { background: rgba(74,158,255,0.12); color: var(--blue); }
    .tl-badge.docs { background: rgba(124,92,252,0.12); color: var(--purple); }
    .tl-badge.merge { background: rgba(255,193,7,0.12); color: #d68910; }
    .tl-badge.refactor { background: rgba(255,107,157,0.12); color: var(--pink); }
    .tl-badge.init { background: rgba(0,196,180,0.12); color: var(--cyan); }

    .tl-msg { font-size: 0.78rem; color: var(--text-sub); line-height: 1.4; flex: 1; }
    .tl-proj-tag {
      font-family: var(--mono); font-size: 0.5rem; font-weight: 700;
      padding: 0.05rem 0.3rem; border-radius: 4px; margin-left: 0.3rem;
    }
    .tl-hash {
      font-family: var(--mono); font-size: 0.6rem; color: var(--text-dim);
      flex-shrink: 0; opacity: 0.5;
    }

    /* PAGINATION */
    .paging {
      display: flex; justify-content: center; align-items: center;
      gap: 0.5rem; margin-top: 1.5rem;
    }
    .page-btn {
      background: var(--card); border: 1px solid var(--border); border-radius: 10px;
      padding: 0.5rem 1rem; cursor: pointer; font-family: var(--body);
      font-size: 0.8rem; font-weight: 700; color: var(--text-sub);
      transition: all 0.2s;
    }
    .page-btn:hover { color: var(--purple); border-color: var(--purple); }
    .page-btn:disabled { opacity: 0.3; cursor: not-allowed; }
    .page-btn.active { background: var(--purple); color: white; border-color: var(--purple); }
    .page-info {
      font-family: var(--mono); font-size: 0.7rem; color: var(--text-dim);
      padding: 0.3rem 0.8rem;
    }
    .page-dots {
      display: flex; gap: 0.3rem; align-items: center;
    }
    .page-dot {
      width: 8px; height: 8px; border-radius: 50%; background: var(--border);
      cursor: pointer; transition: all 0.2s;
    }
    .page-dot.active { background: var(--purple); transform: scale(1.3); }
    .page-dot:hover { background: var(--purple); opacity: 0.6; }

    /* FOOTER */
    .footer {
      text-align: center; margin-top: 2rem; padding: 1rem 0;
      font-size: 0.7rem; color: var(--text-dim); font-weight: 600;
    }

    @media (max-width: 640px) {
      .container { padding: 0.8rem; }
      .header h1 { font-size: 1.5rem; }
      .story-row { grid-template-columns: repeat(2, 1fr); gap: 0.6rem; }
      .story-card { padding: 0.8rem; }
      .story-value { font-size: 1.2rem; }
      .proj-tab { padding: 0.35rem 0.7rem; font-size: 0.7rem; }
      .project-info { padding: 0.8rem; }
      .tl-item { padding: 0.4rem 0.6rem; }
      .tl-hash { display: none; }
    }
  </style>
</head>
