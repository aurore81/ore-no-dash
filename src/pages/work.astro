---
import Base from '../layouts/Base.astro';
---

<Base title="업무" active="work">
  <!-- Project tabs -->
  <div class="flex justify-center gap-2 mb-6 flex-wrap" id="project-tabs"></div>

  <!-- Project info panel -->
  <div id="project-info"></div>

  <!-- Summary stats -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8" id="stats-row"></div>

  <!-- Timeline -->
  <h2 class="text-2xl font-black mb-4 text-text" id="tl-title">타임라인</h2>
  <div id="timeline"></div>
  <div class="flex justify-center gap-3 mt-6 mb-8" id="paging"></div>
</Base>

<style is:inline>
  .proj-tab {
    padding: 0.45rem 1rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    border: 1.5px solid transparent;
    background: var(--color-card);
    color: var(--color-sub);
    transition: all 0.2s;
  }
  .proj-tab:hover {
    background: var(--color-card-hover);
    color: var(--color-text);
  }
  .proj-tab.active {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
  }
</style>

