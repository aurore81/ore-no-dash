---
import Base from '../layouts/Base.astro';
---

<Base title="예약 알림" active="schedule">
  <!-- Anime deco -->
  <div class="sched-deco" id="sched-deco"></div>

  <!-- Header -->
  <div class="text-center mb-8">
    <div class="text-6xl mb-3 sched-icon">⏰</div>
    <h1 class="text-3xl font-black text-text">예약 알림</h1>
    <p class="text-sm text-dim font-bold mt-1">푸시 알림을 예약하세요 ✨</p>
  </div>

  <!-- Create form -->
  <div class="bg-card border-2 border-border rounded-2xl p-6 mb-8 relative overflow-hidden sched-form-card">
    <div class="sched-form-shine"></div>
    <h2 class="text-lg font-black text-gold mb-4 relative z-1">📝 새 알림 예약</h2>

    <div class="grid gap-4 relative z-1">
      <!-- Title -->
      <div>
        <label class="text-xs font-extrabold text-sub uppercase mb-1 block">제목</label>
        <input type="text" id="sched-title" placeholder="알림 제목..." class="sched-input" maxlength="100">
      </div>

      <!-- Message -->
      <div>
        <label class="text-xs font-extrabold text-sub uppercase mb-1 block">내용</label>
        <textarea id="sched-message" placeholder="알림 내용을 입력하세요..." class="sched-input" rows="3" maxlength="500"></textarea>
      </div>

      <!-- Date & Time -->
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="text-xs font-extrabold text-sub uppercase mb-1 block">날짜</label>
          <input type="date" id="sched-date" class="sched-input">
        </div>
        <div>
          <label class="text-xs font-extrabold text-sub uppercase mb-1 block">시간</label>
          <input type="time" id="sched-time" class="sched-input">
        </div>
      </div>

      <!-- Priority -->
      <div>
        <label class="text-xs font-extrabold text-sub uppercase mb-1 block">우선순위</label>
        <div class="flex gap-2" id="priority-pills">
          <button class="priority-pill" data-priority="1">🔵 낮음</button>
          <button class="priority-pill active" data-priority="3">🟢 보통</button>
          <button class="priority-pill" data-priority="4">🟠 높음</button>
          <button class="priority-pill" data-priority="5">🔴 긴급</button>
        </div>
      </div>

      <!-- Repeat -->
      <div>
        <label class="text-xs font-extrabold text-sub uppercase mb-1 block">반복</label>
        <div class="flex gap-2 flex-wrap" id="repeat-pills">
          <button class="repeat-pill active" data-repeat="none">🚫 없음</button>
          <button class="repeat-pill" data-repeat="daily">📅 매일</button>
          <button class="repeat-pill" data-repeat="weekday">💼 평일</button>
          <button class="repeat-pill" data-repeat="weekly">📆 매주</button>
          <button class="repeat-pill" data-repeat="monthly">🗓️ 매달</button>
          <button class="repeat-pill" data-repeat="yearly">🎂 매년</button>
        </div>
      </div>

      <!-- Emoji tag -->
      <div>
        <label class="text-xs font-extrabold text-sub uppercase mb-1 block">태그 이모지</label>
        <div class="flex gap-2 flex-wrap" id="emoji-pills">
          <button class="emoji-pill active" data-emoji="bell">🔔</button>
          <button class="emoji-pill" data-emoji="calendar">📅</button>
          <button class="emoji-pill" data-emoji="warning">⚠️</button>
          <button class="emoji-pill" data-emoji="heart">❤️</button>
          <button class="emoji-pill" data-emoji="star">⭐</button>
          <button class="emoji-pill" data-emoji="coffee">☕</button>
          <button class="emoji-pill" data-emoji="muscle">💪</button>
          <button class="emoji-pill" data-emoji="rocket">🚀</button>
        </div>
      </div>

      <!-- Submit -->
      <button id="sched-submit" class="sched-submit-btn">
        <span class="sched-submit-text">🚀 예약하기!</span>
      </button>
    </div>
  </div>

  <!-- Upcoming list -->
  <div class="mb-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-black text-text">📋 예약 목록</h2>
      <div class="flex gap-2">
        <button id="filter-all" class="list-filter active">전체</button>
        <button id="filter-upcoming" class="list-filter">예정</button>
        <button id="filter-recurring" class="list-filter">반복</button>
        <button id="filter-past" class="list-filter">완료</button>
      </div>
    </div>
    <div id="schedule-list">
      <div class="text-center py-12">
        <div class="text-5xl mb-3">📭</div>
        <p class="text-dim font-bold">예약된 알림이 없어요...</p>
      </div>
    </div>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8" id="sched-stats">
    <div class="bg-card border border-border rounded-xl p-4 text-center sched-stat">
      <div class="text-2xl font-black text-gold" id="stat-total">0</div>
      <div class="text-xs font-extrabold text-dim">전체</div>
    </div>
    <div class="bg-card border border-border rounded-xl p-4 text-center sched-stat">
      <div class="text-2xl font-black text-green" id="stat-upcoming">0</div>
      <div class="text-xs font-extrabold text-dim">예정</div>
    </div>
    <div class="bg-card border border-border rounded-xl p-4 text-center sched-stat">
      <div class="text-2xl font-black text-blue" id="stat-recurring">0</div>
      <div class="text-xs font-extrabold text-dim">반복</div>
    </div>
    <div class="bg-card border border-border rounded-xl p-4 text-center sched-stat">
      <div class="text-2xl font-black text-purple" id="stat-sent">0</div>
      <div class="text-xs font-extrabold text-dim">발송 완료</div>
    </div>
  </div>

  <!-- Toast -->
  <div class="sched-toast" id="toast"></div>
</Base>

<style is:inline>
  /* === SCHEDULE PAGE STYLES === */
  .sched-icon { animation: sched-bounce 2s ease-in-out infinite; display: inline-block; }
  @keyframes sched-bounce {
    0%,100% { transform: translateY(0) rotate(0); }
    25% { transform: translateY(-10px) rotate(-10deg); }
    50% { transform: translateY(-5px) rotate(5deg); }
    75% { transform: translateY(-8px) rotate(-3deg); }
  }

  .sched-deco {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    pointer-events: none; z-index: 0; overflow: hidden;
  }
  .sched-float {
    position: absolute; opacity: 0.15;
    animation: sched-float-up linear infinite;
  }
  @keyframes sched-float-up {
    0% { transform: translateY(110vh) rotate(0deg); }
    100% { transform: translateY(-10vh) rotate(360deg); }
  }

  .sched-form-card { transition: all 0.3s; }
  .sched-form-card:hover { border-color: color-mix(in srgb, var(--color-gold) 30%, transparent); }
  .sched-form-shine {
    position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
    background: linear-gradient(45deg, transparent 40%, rgba(255,215,0,0.03) 50%, transparent 60%);
    animation: form-shine 4s infinite;
  }
  @keyframes form-shine {
    0% { transform: translateX(-100%) rotate(45deg); }
    100% { transform: translateX(100%) rotate(45deg); }
  }

  .sched-input {
    width: 100%; padding: 0.75rem 1rem; border-radius: 0.75rem;
    background: var(--color-bg); border: 2px solid var(--color-border);
    color: var(--color-text); font-weight: 700; font-size: 0.9rem;
    font-family: inherit; transition: all 0.3s; outline: none;
  }
  .sched-input:focus {
    border-color: var(--color-gold);
    box-shadow: 0 0 15px color-mix(in srgb, var(--color-gold) 15%, transparent);
  }
  .sched-input::placeholder { color: var(--color-dim); }

  /* Pills */
  .priority-pill, .repeat-pill, .emoji-pill {
    padding: 0.4rem 0.8rem; border-radius: 9999px;
    font-size: 0.8rem; font-weight: 700; cursor: pointer;
    border: 2px solid var(--color-border);
    background: var(--color-bg); color: var(--color-sub);
    transition: all 0.3s;
  }
  .priority-pill:hover, .repeat-pill:hover, .emoji-pill:hover {
    transform: scale(1.05); border-color: var(--color-sub);
  }
  .priority-pill.active, .repeat-pill.active {
    border-color: var(--color-gold); color: var(--color-gold);
    background: color-mix(in srgb, var(--color-gold) 10%, transparent);
    box-shadow: 0 0 10px color-mix(in srgb, var(--color-gold) 15%, transparent);
  }
  .emoji-pill.active {
    border-color: var(--color-pink);
    background: color-mix(in srgb, var(--color-pink) 10%, transparent);
    box-shadow: 0 0 10px color-mix(in srgb, var(--color-pink) 15%, transparent);
    transform: scale(1.15);
  }

  /* Submit button */
  .sched-submit-btn {
    width: 100%; padding: 1rem; border-radius: 1rem;
    background: linear-gradient(135deg, var(--color-gold), var(--color-orange));
    color: #000; font-weight: 900; font-size: 1.1rem;
    border: none; cursor: pointer; transition: all 0.3s;
    position: relative; overflow: hidden;
  }
  .sched-submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px color-mix(in srgb, var(--color-gold) 40%, transparent);
  }
  .sched-submit-btn:active { transform: scale(0.97); }
  .sched-submit-btn.sending { opacity: 0.7; pointer-events: none; }
  .sched-submit-btn.success {
    background: linear-gradient(135deg, var(--color-green), var(--color-cyan));
  }

  /* List filters */
  .list-filter {
    padding: 0.3rem 0.7rem; border-radius: 9999px;
    font-size: 0.75rem; font-weight: 700; cursor: pointer;
    background: var(--color-bg); color: var(--color-dim);
    border: 1px solid var(--color-border); transition: all 0.3s;
  }
  .list-filter.active {
    background: var(--color-accent); color: white;
    border-color: var(--color-accent);
  }

  /* Schedule item */
  .sched-item {
    background: var(--color-card); border: 2px solid var(--color-border);
    border-radius: 1rem; padding: 1rem 1.25rem; margin-bottom: 0.75rem;
    transition: all 0.3s; animation: sched-item-in 0.4s ease both;
    position: relative; overflow: hidden;
  }
  .sched-item:hover {
    transform: translateX(4px); border-color: color-mix(in srgb, var(--color-gold) 30%, transparent);
  }
  .sched-item.past { opacity: 0.5; }
  .sched-item.recurring { border-left: 4px solid var(--color-blue); }
  @keyframes sched-item-in {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .sched-item-delete {
    position: absolute; top: 8px; right: 12px;
    background: none; border: none; cursor: pointer;
    color: var(--color-dim); font-size: 1rem; transition: all 0.3s;
    opacity: 0;
  }
  .sched-item:hover .sched-item-delete { opacity: 1; }
  .sched-item-delete:hover { color: var(--color-red); transform: scale(1.2); }

  /* Stats */
  .sched-stat {
    transition: all 0.3s;
    animation: sched-stat-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  .sched-stat:nth-child(1) { animation-delay: 0.1s; }
  .sched-stat:nth-child(2) { animation-delay: 0.2s; }
  .sched-stat:nth-child(3) { animation-delay: 0.3s; }
  .sched-stat:nth-child(4) { animation-delay: 0.4s; }
  .sched-stat:hover { transform: translateY(-3px); }
  @keyframes sched-stat-pop {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }

  /* Toast */
  .sched-toast {
    position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%) translateY(100px);
    background: var(--color-card); border: 2px solid var(--color-gold);
    border-radius: 1rem; padding: 0.75rem 1.5rem;
    font-size: 0.9rem; font-weight: 800; color: var(--color-gold);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: 1000; pointer-events: none;
  }
  .sched-toast.show { transform: translateX(-50%) translateY(0); }

  /* Repeat badge */
  .repeat-badge {
    display: inline-flex; align-items: center; gap: 0.2rem;
    padding: 0.15rem 0.5rem; border-radius: 9999px;
    font-size: 0.65rem; font-weight: 800;
    background: color-mix(in srgb, var(--color-blue) 15%, transparent);
    color: var(--color-blue);
  }
  .priority-badge {
    display: inline-block; width: 8px; height: 8px; border-radius: 50%;
  }
  .priority-badge[data-p="1"] { background: var(--color-blue); }
  .priority-badge[data-p="3"] { background: var(--color-green); }
  .priority-badge[data-p="4"] { background: var(--color-orange); }
  .priority-badge[data-p="5"] { background: var(--color-red); box-shadow: 0 0 8px var(--color-red); }
</style>

<script>
  // === Types ===
  interface Schedule {
    id: string;
    title: string;
    message: string;
    datetime: string; // ISO string
    priority: number;
    repeat: string;
    emoji: string;
    status: 'pending' | 'sent' | 'recurring';
    ntfyId?: string;
    createdAt: string;
    lastSent?: string;
  }

  const NTFY_TOPIC = 'aurore-deploy-af55e122';
  const STORAGE_KEY = 'aurore-schedules';

  // === State ===
  let schedules: Schedule[] = [];
  let selectedPriority = 3;
  let selectedRepeat = 'none';
  let selectedEmoji = 'bell';
  let currentFilter = 'all';

  // === Storage ===
  function loadSchedules(): Schedule[] {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
    } catch { return []; }
  }
  function saveSchedules() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(schedules));
  }

  // === Toast ===
  function showToast(msg: string) {
    const toast = document.getElementById('toast');
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 3000);
  }

  // === Send to ntfy (JSON body — supports UTF-8 Korean) ===
  async function sendToNtfy(sched: Schedule, scheduledTime?: string): Promise<string | null> {
    const payload: Record<string, any> = {
      topic: NTFY_TOPIC,
      title: sched.title,
      message: sched.message,
      priority: sched.priority,
      tags: [sched.emoji],
    };
    if (scheduledTime) {
      payload.delay = String(Math.floor(new Date(scheduledTime).getTime() / 1000));
    }

    try {
      const res = await fetch('https://ntfy.sh', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error(`ntfy error: ${res.status}`);
      const data = await res.json();
      return data.id || null;
    } catch (err) {
      console.error('ntfy send failed:', err);
      return null;
    }
  }

  // === Calculate next occurrence for recurring ===
  function getNextOccurrence(sched: Schedule): Date | null {
    const base = new Date(sched.datetime);
    const now = new Date();
    let next = new Date(base);

    // Set time from original
    next.setHours(base.getHours(), base.getMinutes(), 0, 0);

    switch (sched.repeat) {
      case 'daily':
        next.setFullYear(now.getFullYear(), now.getMonth(), now.getDate());
        if (next <= now) next.setDate(next.getDate() + 1);
        break;
      case 'weekday':
        next.setFullYear(now.getFullYear(), now.getMonth(), now.getDate());
        if (next <= now) next.setDate(next.getDate() + 1);
        while (next.getDay() === 0 || next.getDay() === 6) next.setDate(next.getDate() + 1);
        break;
      case 'weekly':
        next.setFullYear(now.getFullYear(), now.getMonth(), now.getDate());
        const targetDay = base.getDay();
        while (next.getDay() !== targetDay || next <= now) next.setDate(next.getDate() + 1);
        break;
      case 'monthly':
        next.setFullYear(now.getFullYear(), now.getMonth(), base.getDate());
        if (next <= now) next.setMonth(next.getMonth() + 1);
        break;
      case 'yearly':
        next.setFullYear(now.getFullYear(), base.getMonth(), base.getDate());
        if (next <= now) next.setFullYear(next.getFullYear() + 1);
        break;
      default:
        return null;
    }
    return next;
  }

  // === Schedule recurring notifications ===
  async function scheduleRecurring() {
    const recurring = schedules.filter(s => s.repeat !== 'none' && s.status !== 'sent');
    for (const sched of recurring) {
      const next = getNextOccurrence(sched);
      if (!next) continue;

      const diffMs = next.getTime() - Date.now();
      // Only schedule if within next 24 hours and not already scheduled recently
      if (diffMs > 0 && diffMs < 24 * 60 * 60 * 1000) {
        const lastSent = sched.lastSent ? new Date(sched.lastSent) : null;
        const nextStr = next.toISOString();
        if (lastSent && Math.abs(lastSent.getTime() - next.getTime()) < 60000) continue;

        const ntfyId = await sendToNtfy(sched, nextStr);
        if (ntfyId) {
          sched.ntfyId = ntfyId;
          sched.status = 'recurring';
          saveSchedules();
        }
      }
    }
  }

  // === Repeat label ===
  const repeatLabels: Record<string, string> = {
    none: '', daily: '매일', weekday: '평일', weekly: '매주', monthly: '매달', yearly: '매년'
  };

  // === Render list ===
  function renderList() {
    const container = document.getElementById('schedule-list');
    if (!container) return;

    const now = new Date();
    let filtered = [...schedules];

    if (currentFilter === 'upcoming') {
      filtered = filtered.filter(s => new Date(s.datetime) > now && s.repeat === 'none');
    } else if (currentFilter === 'recurring') {
      filtered = filtered.filter(s => s.repeat !== 'none');
    } else if (currentFilter === 'past') {
      filtered = filtered.filter(s => new Date(s.datetime) <= now && s.repeat === 'none');
    }

    // Sort: upcoming first, then past
    filtered.sort((a, b) => {
      const aTime = new Date(a.datetime).getTime();
      const bTime = new Date(b.datetime).getTime();
      const aPast = aTime <= now.getTime() && a.repeat === 'none';
      const bPast = bTime <= now.getTime() && b.repeat === 'none';
      if (aPast !== bPast) return aPast ? 1 : -1;
      return aTime - bTime;
    });

    if (filtered.length === 0) {
      container.innerHTML = `
        <div class="text-center py-12">
          <div class="text-5xl mb-3">📭</div>
          <p class="text-dim font-bold">해당 알림이 없어요...</p>
        </div>`;
      return;
    }

    container.innerHTML = filtered.map((s, i) => {
      const dt = new Date(s.datetime);
      const isPast = dt <= now && s.repeat === 'none';
      const isRecurring = s.repeat !== 'none';
      const nextOcc = isRecurring ? getNextOccurrence(s) : null;

      const dateStr = dt.toLocaleDateString('ko-KR', { month: 'short', day: 'numeric', weekday: 'short' });
      const timeStr = dt.toLocaleTimeString('ko-KR', { hour: '2-digit', minute: '2-digit', hour12: false });
      const nextStr = nextOcc ? nextOcc.toLocaleDateString('ko-KR', { month: 'short', day: 'numeric' }) + ' ' + nextOcc.toLocaleTimeString('ko-KR', { hour: '2-digit', minute: '2-digit', hour12: false }) : '';

      const emojiMap: Record<string, string> = { bell: '🔔', calendar: '📅', warning: '⚠️', heart: '❤️', star: '⭐', coffee: '☕', muscle: '💪', rocket: '🚀' };

      return `
        <div class="sched-item ${isPast ? 'past' : ''} ${isRecurring ? 'recurring' : ''}" style="animation-delay:${i * 0.05}s" data-id="${s.id}">
          <button class="sched-item-delete" data-id="${s.id}" title="삭제">✕</button>
          <div class="flex items-start gap-3">
            <div class="text-2xl shrink-0">${emojiMap[s.emoji] || '🔔'}</div>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="priority-badge" data-p="${s.priority}"></span>
                <span class="text-sm font-black text-text">${s.title}</span>
                ${isRecurring ? `<span class="repeat-badge">🔄 ${repeatLabels[s.repeat]}</span>` : ''}
              </div>
              <div class="text-xs text-sub font-bold mb-1">${s.message}</div>
              <div class="flex items-center gap-3 text-xs text-dim font-bold">
                <span>${dateStr} ${timeStr}</span>
                ${isRecurring && nextStr ? `<span class="text-blue">→ 다음: ${nextStr}</span>` : ''}
                ${isPast ? '<span class="text-green">✅ 발송됨</span>' : ''}
              </div>
            </div>
          </div>
        </div>
      `;
    }).join('');

    // Delete handlers
    container.querySelectorAll('.sched-item-delete').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = (btn as HTMLElement).dataset.id;
        if (!id) return;
        schedules = schedules.filter(s => s.id !== id);
        saveSchedules();
        renderList();
        updateStats();
        showToast('🗑️ 삭제했어요!');
      });
    });
  }

  // === Update stats ===
  function updateStats() {
    const now = new Date();
    const total = schedules.length;
    const upcoming = schedules.filter(s => new Date(s.datetime) > now && s.repeat === 'none').length;
    const recurring = schedules.filter(s => s.repeat !== 'none').length;
    const sent = schedules.filter(s => new Date(s.datetime) <= now && s.repeat === 'none').length;

    const setNum = (id: string, val: number) => {
      const el = document.getElementById(id);
      if (el) el.textContent = val.toString();
    };
    setNum('stat-total', total);
    setNum('stat-upcoming', upcoming);
    setNum('stat-recurring', recurring);
    setNum('stat-sent', sent);
  }

  // === Init form defaults ===
  function initForm() {
    const now = new Date();
    now.setMinutes(now.getMinutes() + 30);
    const dateInput = document.getElementById('sched-date') as HTMLInputElement;
    const timeInput = document.getElementById('sched-time') as HTMLInputElement;
    if (dateInput) dateInput.value = now.toISOString().slice(0, 10);
    if (timeInput) timeInput.value = now.toTimeString().slice(0, 5);
  }

  // === Pill selectors ===
  function setupPills(containerId: string, callback: (val: string) => void) {
    const container = document.getElementById(containerId);
    if (!container) return;
    container.querySelectorAll('button').forEach(btn => {
      btn.addEventListener('click', () => {
        container.querySelectorAll('button').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const val = btn.dataset.priority || btn.dataset.repeat || btn.dataset.emoji || '';
        callback(val);
      });
    });
  }

  // === Filter buttons ===
  function setupFilters() {
    ['all', 'upcoming', 'recurring', 'past'].forEach(f => {
      const btn = document.getElementById(`filter-${f}`);
      if (!btn) return;
      btn.addEventListener('click', () => {
        document.querySelectorAll('.list-filter').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentFilter = f;
        renderList();
      });
    });
  }

  // === Submit handler ===
  async function handleSubmit() {
    const titleEl = document.getElementById('sched-title') as HTMLInputElement;
    const msgEl = document.getElementById('sched-message') as HTMLTextAreaElement;
    const dateEl = document.getElementById('sched-date') as HTMLInputElement;
    const timeEl = document.getElementById('sched-time') as HTMLInputElement;
    const submitBtn = document.getElementById('sched-submit') as HTMLButtonElement;

    if (!titleEl?.value.trim() || !dateEl?.value || !timeEl?.value) {
      showToast('⚠️ 제목, 날짜, 시간을 입력해주세요！');
      return;
    }

    const datetime = new Date(`${dateEl.value}T${timeEl.value}:00`);
    if (selectedRepeat === 'none' && datetime <= new Date()) {
      showToast('⚠️ 미래 시간을 선택해주세요！');
      return;
    }

    submitBtn.classList.add('sending');
    const submitText = submitBtn.querySelector('.sched-submit-text');
    if (submitText) submitText.textContent = '⏳ 전송 중...';

    const sched: Schedule = {
      id: Date.now().toString(36) + Math.random().toString(36).slice(2, 6),
      title: titleEl.value.trim(),
      message: msgEl.value.trim() || titleEl.value.trim(),
      datetime: datetime.toISOString(),
      priority: selectedPriority,
      repeat: selectedRepeat,
      emoji: selectedEmoji,
      status: selectedRepeat !== 'none' ? 'recurring' : 'pending',
      createdAt: new Date().toISOString(),
    };

    // Send to ntfy
    let ntfyId: string | null = null;
    if (selectedRepeat === 'none') {
      ntfyId = await sendToNtfy(sched, datetime.toISOString());
    } else {
      const next = getNextOccurrence(sched);
      if (next) {
        ntfyId = await sendToNtfy(sched, next.toISOString());
      }
    }

    if (ntfyId) {
      sched.ntfyId = ntfyId;
      schedules.push(sched);
      saveSchedules();
      renderList();
      updateStats();

      submitBtn.classList.remove('sending');
      submitBtn.classList.add('success');
      if (submitText) submitText.textContent = '✅ 예약 완료!';
      showToast('✨ 알림 예약 성공! ' + (selectedRepeat !== 'none' ? '🔄 반복 설정됨' : ''));

      setTimeout(() => {
        submitBtn.classList.remove('success');
        if (submitText) submitText.textContent = '🚀 예약하기!';
      }, 2000);

      // Reset form
      titleEl.value = '';
      msgEl.value = '';
      initForm();
    } else {
      submitBtn.classList.remove('sending');
      if (submitText) submitText.textContent = '🚀 예약하기!';
      showToast('❌ 전송 실패... 다시 시도해주세요');
    }
  }

  // === Floating deco ===
  function initDeco() {
    const container = document.getElementById('sched-deco');
    if (!container) return;
    const items = ['⏰', '📅', '🔔', '⏳', '🗓️', '✨', '💫', '🎯'];
    for (let i = 0; i < 8; i++) {
      const el = document.createElement('div');
      el.className = 'sched-float';
      el.textContent = items[i % items.length];
      el.style.left = Math.random() * 100 + '%';
      el.style.animationDuration = (15 + Math.random() * 20) + 's';
      el.style.animationDelay = (-Math.random() * 20) + 's';
      el.style.fontSize = (0.7 + Math.random() * 0.6) + 'rem';
      container.appendChild(el);
    }
  }

  // === Init ===
  schedules = loadSchedules();
  initForm();
  initDeco();
  setupPills('priority-pills', v => { selectedPriority = parseInt(v) || 3; });
  setupPills('repeat-pills', v => { selectedRepeat = v; });
  setupPills('emoji-pills', v => { selectedEmoji = v; });
  setupFilters();
  renderList();
  updateStats();

  // Schedule recurring on page load
  scheduleRecurring();

  // Submit
  document.getElementById('sched-submit')?.addEventListener('click', handleSubmit);
</script>
