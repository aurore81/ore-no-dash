---
import Base from '../layouts/Base.astro';
---

<Base title="통계" active="stats">
  <!-- Header badge -->
  <div class="text-center mb-6">
    <div class="text-sm font-mono text-dim" id="header-badge">Loading...</div>
  </div>

  <!-- Summary stats -->
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mb-8" id="stats-row"></div>

  <!-- Commit Heatmap -->
  <div class="mb-8">
    <h2 class="text-xl font-black mb-3 text-text">Commit Heatmap</h2>
    <div class="bg-card border border-border rounded-2xl p-5 overflow-x-auto">
      <div id="heatmap-months" class="flex text-[0.55rem] font-mono text-dim mb-1" style="padding-left:28px"></div>
      <div class="flex gap-0">
        <div id="heatmap-days" class="flex flex-col gap-[3px] text-[0.55rem] font-mono text-dim shrink-0" style="width:28px;padding-top:1px"></div>
        <div id="heatmap-grid" class="flex gap-[3px]"></div>
      </div>
      <div class="flex items-center justify-end gap-2 mt-3 text-[0.55rem] font-mono text-dim">
        <span>적음</span>
        <div class="flex gap-1">
          <div class="w-[11px] h-[11px] rounded-[2px]" style="background:var(--color-border)"></div>
          <div class="w-[11px] h-[11px] rounded-[2px]" style="background:color-mix(in srgb, var(--color-accent) 30%, transparent)"></div>
          <div class="w-[11px] h-[11px] rounded-[2px]" style="background:color-mix(in srgb, var(--color-accent) 55%, transparent)"></div>
          <div class="w-[11px] h-[11px] rounded-[2px]" style="background:color-mix(in srgb, var(--color-accent) 80%, transparent)"></div>
          <div class="w-[11px] h-[11px] rounded-[2px]" style="background:var(--color-accent)"></div>
        </div>
        <span>많음</span>
      </div>
    </div>
  </div>

  <!-- Charts row -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <!-- By Type -->
    <div>
      <h2 class="text-xl font-black mb-3 text-text">By Type</h2>
      <div class="bg-card border border-border rounded-2xl p-5" id="type-chart"></div>
    </div>
    <!-- By Project -->
    <div>
      <h2 class="text-xl font-black mb-3 text-text">By Project</h2>
      <div class="bg-card border border-border rounded-2xl p-5" id="proj-chart"></div>
    </div>
  </div>

  <!-- Time charts -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <!-- By Hour -->
    <div>
      <h2 class="text-xl font-black mb-3 text-text">By Hour</h2>
      <div class="bg-card border border-border rounded-2xl p-5">
        <div class="flex items-end gap-[2px] h-24" id="hour-chart"></div>
        <div class="flex gap-[2px] mt-1" id="hour-labels"></div>
      </div>
    </div>
    <!-- By Day -->
    <div>
      <h2 class="text-xl font-black mb-3 text-text">By Day of Week</h2>
      <div class="bg-card border border-border rounded-2xl p-5">
        <div class="flex items-end gap-2 h-28" id="week-chart"></div>
      </div>
    </div>
  </div>

  <!-- Timeline -->
  <div class="mb-8">
    <h2 class="text-2xl font-black mb-4 text-text">Timeline</h2>
    <div class="bg-card border border-border rounded-2xl p-5">
      <div class="flex gap-2 mb-4 flex-wrap" id="tl-controls"></div>
      <div id="timeline"></div>
      <button class="w-full py-3 mt-3 rounded-xl bg-bg border border-border text-sm font-bold text-sub hover:text-accent hover:border-accent transition-all" id="show-more">더 보기</button>
    </div>
  </div>
</Base>

<style is:inline>
  .heatmap-cell {
    width: 11px; height: 11px; border-radius: 2px;
    position: relative; cursor: pointer;
  }
  .heatmap-cell:hover { outline: 2px solid var(--color-accent); outline-offset: -1px; }
  .heatmap-tooltip {
    position: fixed; z-index: 1000;
    background: var(--color-text); color: var(--color-bg);
    font-size: 0.65rem; font-family: var(--font-mono);
    padding: 4px 8px; border-radius: 6px;
    pointer-events: none; white-space: nowrap;
    transform: translate(-50%, -100%);
    margin-top: -8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }
  .tl-filter-btn {
    padding: 0.3rem 0.7rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    cursor: pointer;
    border: 1.5px solid transparent;
    background: var(--color-bg);
    color: var(--color-dim);
    font-family: var(--font-mono);
    transition: all 0.2s;
  }
  .tl-filter-btn:hover { color: var(--color-accent); }
  .tl-filter-btn.active {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
  }
</style>

<script>
  interface CommitData {
    iso: string;
    d: string;
    t: string;
    m: string;
    p: string;
    h: string;
  }

  let DATA: CommitData[] = [];
  let tlPage = 0;
  const TL_PAGE_SIZE = 30;
  let tlFilter = 'all';

  const badgeColors: Record<string, string> = {
    feat: 'bg-green/15 text-green',
    fix: 'bg-blue/15 text-blue',
    docs: 'bg-purple/15 text-purple',
    chore: 'bg-dim/10 text-dim',
    test: 'bg-orange/15 text-orange',
    refactor: 'bg-pink/15 text-pink',
  };

  const projColors: Record<string, string> = {
    'sinsa-agency': '#7c5cfc', 'rigel-tax': '#ff6b4a', 'Template': '#2ecf7a',
    'Template-v2': '#00c4b4', 'Template-v3': '#55efc4',
    'admin-sinsa': '#4a9eff', 'kkachi-omuk': '#ffc107',
    'ls-tax-next': '#636e72', 'home-dash': '#ff6b9d', 'dotfiles': '#999aaa'
  };

  const barColors: Record<string, string> = {
    feat: 'var(--color-green)', fix: 'var(--color-blue)', docs: 'var(--color-purple)',
    chore: 'var(--color-dim)', test: 'var(--color-orange)', refactor: 'var(--color-pink)'
  };

  async function init() {
    const res = await fetch('https://api.aurore.work/commits?limit=2000');
    const json = await res.json();
    DATA = (json.commits || json).map((c: any) => ({
      d: c.d || c.date,
      iso: c.iso,
      t: c.t || c.type,
      m: c.m || c.message,
      p: c.p || c.project,
      h: c.h || c.hash,
    }));
    DATA.sort((a, b) => b.iso.localeCompare(a.iso));

    renderStatsRow();
    renderHeatmap();
    renderTypeChart();
    renderProjChart();
    renderHourChart();
    renderWeekChart();
    renderTlControls();
    renderTimeline();
  }

  function renderHeatmap() {
    const grid = document.getElementById('heatmap-grid');
    const monthsEl = document.getElementById('heatmap-months');
    const daysEl = document.getElementById('heatmap-days');
    if (!grid || !monthsEl || !daysEl) return;

    // Count commits per date
    const counts: Record<string, number> = {};
    DATA.forEach(c => { counts[c.d] = (counts[c.d] || 0) + 1; });

    // Build 365 days ending today
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const startDate = new Date(today);
    startDate.setDate(startDate.getDate() - 364);

    // Adjust start to the nearest Monday (ISO week start)
    const startDay = startDate.getDay(); // 0=Sun
    const adjustedStart = new Date(startDate);
    // Go back to previous Monday (or stay if already Monday)
    const diff = startDay === 0 ? -6 : 1 - startDay;
    adjustedStart.setDate(adjustedStart.getDate() + diff);

    // Day labels (Mon/Wed/Fri)
    const dayLabels = ['', '월', '', '수', '', '금', ''];
    dayLabels.forEach(label => {
      const el = document.createElement('div');
      el.style.height = '11px';
      el.style.lineHeight = '11px';
      el.textContent = label;
      daysEl.appendChild(el);
    });

    // Tooltip element
    let tooltip: HTMLDivElement | null = null;

    // Build weeks (columns)
    const d = new Date(adjustedStart);
    let currentMonth = -1;
    let weekCount = 0;
    const monthPositions: { month: number; week: number }[] = [];

    while (d <= today) {
      const weekCol = document.createElement('div');
      weekCol.className = 'flex flex-col gap-[3px]';

      for (let day = 0; day < 7; day++) {
        const dateStr = d.toISOString().slice(0, 10);
        const count = counts[dateStr] || 0;
        const cell = document.createElement('div');
        cell.className = 'heatmap-cell';

        // Track month changes (use first day that's within range)
        if (d >= startDate && d.getMonth() !== currentMonth) {
          currentMonth = d.getMonth();
          monthPositions.push({ month: currentMonth, week: weekCount });
        }

        if (d > today || d < startDate) {
          cell.style.background = 'transparent';
        } else if (count === 0) {
          cell.style.background = 'var(--color-border)';
        } else if (count <= 2) {
          cell.style.background = 'color-mix(in srgb, var(--color-accent) 30%, transparent)';
        } else if (count <= 5) {
          cell.style.background = 'color-mix(in srgb, var(--color-accent) 55%, transparent)';
        } else if (count <= 9) {
          cell.style.background = 'color-mix(in srgb, var(--color-accent) 80%, transparent)';
        } else {
          cell.style.background = 'var(--color-accent)';
        }

        // Tooltip events
        if (d >= startDate && d <= today) {
          const label = dateStr + ': ' + count + '커밋';
          cell.addEventListener('mouseenter', function(e) {
            if (tooltip) tooltip.remove();
            tooltip = document.createElement('div');
            tooltip.className = 'heatmap-tooltip';
            tooltip.textContent = label;
            document.body.appendChild(tooltip);
            const rect = (e.target as HTMLElement).getBoundingClientRect();
            tooltip.style.left = (rect.left + rect.width / 2) + 'px';
            tooltip.style.top = (rect.top - 4) + 'px';
          });
          cell.addEventListener('mouseleave', function() {
            if (tooltip) { tooltip.remove(); tooltip = null; }
          });
        }

        weekCol.appendChild(cell);
        d.setDate(d.getDate() + 1);
      }

      grid.appendChild(weekCol);
      weekCount++;
    }

    // Month labels
    const monthNames = ['1월', '2월', '3월', '4월', '5월', '6월', '7월', '8월', '9월', '10월', '11월', '12월'];
    const cellW = 14; // 11px + 3px gap
    let lastLabelEnd = 0;
    monthPositions.forEach(({ month, week }) => {
      const left = week * cellW;
      if (left < lastLabelEnd) return; // skip overlapping
      const span = document.createElement('span');
      span.textContent = monthNames[month];
      span.style.position = 'absolute';
      span.style.left = left + 'px';
      monthsEl.appendChild(span);
      lastLabelEnd = left + 24;
    });
    monthsEl.style.position = 'relative';
    monthsEl.style.height = '14px';
  }

  function renderStatsRow() {
    const el = document.getElementById('stats-row');
    if (!el) return;

    const dates = [...new Set(DATA.map(c => c.d))].sort();
    const first = dates[0], last = dates[dates.length - 1];
    const daySpan = Math.ceil((new Date(last).getTime() - new Date(first).getTime()) / 86400000) + 1;
    const activeDays = dates.length;
    const avgPerDay = (DATA.length / activeDays).toFixed(1);

    let maxStreak = 0, cur = 0;
    const dateSet = new Set(dates);
    const d = new Date(first);
    const end = new Date(last);
    while (d <= end) {
      if (dateSet.has(d.toISOString().slice(0, 10))) { cur++; maxStreak = Math.max(maxStreak, cur); }
      else { cur = 0; }
      d.setDate(d.getDate() + 1);
    }

    const dayCounts: Record<string, number> = {};
    DATA.forEach(c => { dayCounts[c.d] = (dayCounts[c.d] || 0) + 1; });
    const bestDay = Object.entries(dayCounts).sort((a, b) => b[1] - a[1])[0];

    const badge = document.getElementById('header-badge');
    if (badge) badge.textContent = `${first} ~ ${last} // ${DATA.length} commits in ${daySpan} days`;

    const items = [
      { value: DATA.length.toString(), label: 'TOTAL', color: 'text-accent' },
      { value: activeDays.toString(), label: 'ACTIVE DAYS', color: 'text-blue' },
      { value: avgPerDay, label: 'AVG/DAY', color: 'text-green' },
      { value: maxStreak.toString(), label: 'MAX STREAK', color: 'text-orange' },
      { value: bestDay[1].toString(), label: 'BEST DAY', color: 'text-pink' },
      { value: daySpan + '일', label: 'SPAN', color: 'text-cyan' },
    ];

    el.innerHTML = items.map(s => `
      <div class="bg-card border border-border rounded-2xl p-4 text-center">
        <div class="text-2xl font-black ${s.color}">${s.value}</div>
        <div class="text-[0.65rem] font-bold text-dim mt-1 uppercase">${s.label}</div>
      </div>
    `).join('');
  }

  function renderTypeChart() {
    const el = document.getElementById('type-chart');
    if (!el) return;

    const counts: Record<string, number> = {};
    DATA.forEach(c => { counts[c.t] = (counts[c.t] || 0) + 1; });
    const sorted = Object.entries(counts).sort((a, b) => b[1] - a[1]);
    const max = sorted[0][1];

    el.innerHTML = sorted.map(([type, count]) => {
      const pct = (count / max * 100).toFixed(0);
      const bg = barColors[type] || 'var(--color-dim)';
      return `
        <div class="flex items-center gap-3 mb-2">
          <div class="text-xs font-mono text-sub w-16 text-right uppercase">${type}</div>
          <div class="flex-1 h-6 bg-bg rounded-lg overflow-hidden">
            <div class="h-full rounded-lg flex items-center pl-2 text-xs font-mono font-bold text-white transition-all duration-700" style="width:${pct}%;background:${bg}">${count}</div>
          </div>
        </div>
      `;
    }).join('');
  }

  function renderProjChart() {
    const el = document.getElementById('proj-chart');
    if (!el) return;

    const counts: Record<string, number> = {};
    DATA.forEach(c => { counts[c.p] = (counts[c.p] || 0) + 1; });
    const sorted = Object.entries(counts).sort((a, b) => b[1] - a[1]);
    const total = DATA.length;

    // SVG donut
    let cum = 0;
    const r = 65, cx = 80, cy = 80;
    let paths = '';

    sorted.forEach(([proj, count]) => {
      const s = (cum / total) * 360 - 90;
      const e = ((cum + count) / total) * 360 - 90;
      const la = (e - s > 180) ? 1 : 0;
      const x1 = cx + r * Math.cos(s * Math.PI / 180);
      const y1 = cy + r * Math.sin(s * Math.PI / 180);
      const x2 = cx + r * Math.cos(e * Math.PI / 180);
      const y2 = cy + r * Math.sin(e * Math.PI / 180);
      paths += `<path d="M${cx},${cy} L${x1},${y1} A${r},${r} 0 ${la} 1 ${x2},${y2} Z" fill="${projColors[proj] || '#ddd'}" opacity="0.85"/>`;
      cum += count;
    });

    const svg = `<svg viewBox="0 0 160 160" class="w-36 h-36 mx-auto">${paths}<circle cx="${cx}" cy="${cy}" r="36" fill="var(--color-card)"/></svg>`;

    const legend = sorted.map(([proj, count]) => {
      const pct = (count / total * 100).toFixed(1);
      return `
        <div class="flex items-center gap-2 text-sm text-sub py-1 px-2 rounded-lg hover:bg-bg transition-colors">
          <div class="w-2.5 h-2.5 rounded-sm shrink-0" style="background:${projColors[proj] || '#ddd'}"></div>
          <span class="flex-1 truncate">${proj}</span>
          <span class="font-mono text-xs text-dim">${count} (${pct}%)</span>
        </div>
      `;
    }).join('');

    el.innerHTML = `
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <div class="relative">
          ${svg}
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <div class="text-2xl font-black text-accent">${total}</div>
            <div class="text-[0.55rem] text-dim">TOTAL</div>
          </div>
        </div>
        <div class="flex-1 w-full">${legend}</div>
      </div>
    `;
  }

  function renderHourChart() {
    const el = document.getElementById('hour-chart');
    const labels = document.getElementById('hour-labels');
    if (!el || !labels) return;

    const counts = new Array(24).fill(0);
    DATA.forEach(c => { counts[parseInt(c.iso.slice(11, 13))]++; });
    const max = Math.max(...counts);

    for (let h = 0; h < 24; h++) {
      const pct = max > 0 ? (counts[h] / max * 100) : 0;
      const bar = document.createElement('div');
      bar.className = 'flex-1 rounded-t min-w-[6px] transition-all relative group cursor-pointer';
      bar.style.height = Math.max(pct, 2) + '%';
      bar.style.background = counts[h] > 0 ? `color-mix(in srgb, var(--color-accent) ${Math.round(15 + (counts[h] / max) * 85)}%, transparent)` : 'var(--color-bg)';
      bar.innerHTML = `<div class="hidden group-hover:block absolute bottom-full left-1/2 -translate-x-1/2 mb-1 bg-text text-bg text-[0.5rem] font-mono px-1.5 py-0.5 rounded whitespace-nowrap">${h}시: ${counts[h]}</div>`;
      el.appendChild(bar);

      const lbl = document.createElement('span');
      lbl.className = 'flex-1 text-center font-mono text-[0.45rem] text-dim';
      lbl.textContent = h % 3 === 0 ? h.toString() : '';
      labels.appendChild(lbl);
    }
  }

  function renderWeekChart() {
    const el = document.getElementById('week-chart');
    if (!el) return;

    const dayNames = ['일', '월', '화', '수', '목', '금', '토'];
    const counts = new Array(7).fill(0);
    DATA.forEach(c => { counts[new Date(c.d).getDay()]++; });
    const max = Math.max(...counts);

    for (let d = 0; d < 7; d++) {
      const pct = max > 0 ? (counts[d] / max * 100) : 0;
      const isWeekend = d === 0 || d === 6;
      const group = document.createElement('div');
      group.className = 'flex-1 flex flex-col items-center gap-1';
      group.innerHTML = `
        <div class="text-sm font-mono font-bold ${isWeekend ? 'text-pink' : 'text-sub'}">${counts[d]}</div>
        <div class="w-full rounded-t transition-all" style="height:${Math.max(pct, 3)}%;background:${isWeekend ? 'var(--color-pink)' : 'var(--color-accent)'}"></div>
        <div class="text-xs font-mono text-dim">${dayNames[d]}</div>
      `;
      el.appendChild(group);
    }
  }

  function renderTlControls() {
    const el = document.getElementById('tl-controls');
    if (!el) return;

    ['all', 'feat', 'fix', 'docs', 'chore', 'test'].forEach(f => {
      const btn = document.createElement('button');
      btn.className = 'tl-filter-btn' + (f === 'all' ? ' active' : '');
      btn.textContent = f === 'all' ? 'ALL' : f.toUpperCase();
      btn.addEventListener('click', () => {
        el.querySelectorAll('.tl-filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        tlFilter = f;
        tlPage = 0;
        const tl = document.getElementById('timeline');
        if (tl) tl.innerHTML = '';
        renderTimeline();
      });
      el.appendChild(btn);
    });
  }

  function renderTimeline() {
    const el = document.getElementById('timeline');
    if (!el) return;

    const filtered = tlFilter === 'all' ? DATA : DATA.filter(c => c.t === tlFilter);
    const start = tlPage * TL_PAGE_SIZE;
    const slice = filtered.slice(start, start + TL_PAGE_SIZE);

    const grouped: Record<string, CommitData[]> = {};
    slice.forEach(c => { if (!grouped[c.d]) grouped[c.d] = []; grouped[c.d].push(c); });

    Object.keys(grouped).sort((a, b) => b.localeCompare(a)).forEach(date => {
      const day = document.createElement('div');
      day.className = 'mb-4';
      day.innerHTML = `<div class="text-sm font-black text-accent mb-2">${date} <span class="text-xs font-mono text-dim ml-1">${grouped[date].length}</span></div>`;

      grouped[date].forEach(c => {
        const badge = badgeColors[c.t] || 'bg-dim/10 text-dim';
        const time = c.iso.slice(11, 16);
        const pColor = projColors[c.p] || '#666';
        const item = document.createElement('div');
        item.className = 'flex items-start gap-2 py-1.5 px-2 rounded-lg hover:bg-bg transition-colors';
        item.innerHTML = `
          <span class="text-[0.6rem] font-extrabold px-1.5 py-0.5 rounded-full ${badge} shrink-0 mt-0.5 uppercase">${c.t}</span>
          <span class="text-sm text-sub flex-1">${c.m}<span class="text-[0.55rem] font-mono font-bold ml-1.5 px-1 py-0.5 rounded" style="background:${pColor}15;color:${pColor}">${c.p}</span></span>
          <span class="text-xs font-mono text-dim shrink-0">${time}</span>
        `;
        day.appendChild(item);
      });

      el.appendChild(day);
    });

    const showMore = document.getElementById('show-more');
    if (showMore) showMore.style.display = (start + TL_PAGE_SIZE >= filtered.length) ? 'none' : 'block';
  }

  document.getElementById('show-more')?.addEventListener('click', () => { tlPage++; renderTimeline(); });

  init();
</script>
