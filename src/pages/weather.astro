---
import Base from '../layouts/Base.astro';
---

<Base title="날씨" active="weather">
  <!-- Location with mini map -->
  <div class="rounded-2xl overflow-hidden mb-5 relative border border-border">
    <div id="map" style="height:160px;width:100%;z-index:1"></div>
    <div class="absolute bottom-3 left-3 z-10 bg-bg/90 backdrop-blur-md rounded-lg px-3 py-1.5 border border-border">
      <span class="text-xs font-bold text-accent" id="nav-loc">📍 위치 확인 중...</span>
    </div>
  </div>

  <!-- Content area -->
  <div id="content">
    <div class="text-center py-16">
      <div class="text-6xl mb-4 animate-spin-slow">🌀</div>
      <p class="text-sm font-bold text-dim">날씨 데이터 불러오는 중...</p>
      <div class="w-48 h-1 bg-border rounded-full mx-auto mt-4 overflow-hidden">
        <div class="h-full rounded-full bg-gradient-to-r from-pink via-gold to-cyan loading-slide"></div>
      </div>
    </div>
  </div>
</Base>

<!-- Leaflet CSS & JS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style is:inline>
  .animate-spin-slow { animation: spin-slow 2s ease-in-out infinite; }
  @keyframes spin-slow { 0%{transform:rotate(0) scale(1)} 50%{transform:rotate(180deg) scale(1.1)} 100%{transform:rotate(360deg) scale(1)} }
  .loading-slide { width:40%; animation: slide 1.5s ease-in-out infinite; }
  @keyframes slide { 0%{transform:translateX(-100%)} 100%{transform:translateX(350%)} }

  /* Big temp */
  .hero-temp {
    font-size: 6rem; font-weight: 900; line-height: 1;
    background: linear-gradient(135deg, var(--color-text) 40%, var(--color-gold));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  @media (min-width: 640px) { .hero-temp { font-size: 8rem; } }

  /* Weather icon bounce */
  .w-bounce { animation: w-bounce 3s ease-in-out infinite; display:inline-block; }
  @keyframes w-bounce { 0%,100%{transform:translateY(0) rotate(0)} 50%{transform:translateY(-12px) rotate(5deg)} }

  /* Metric card */
  .m-card { transition: all 0.3s; }
  .m-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,0.15); }

  /* Sun arc */
  .sun-arc { position:relative; height:140px; max-width:380px; margin:0 auto; overflow:hidden; }
  .sun-arc-track { position:absolute; bottom:0; left:8%; right:8%; height:120px; border:2px dashed var(--color-border); border-bottom:none; border-radius:50% 50% 0 0; }
  .sun-arc-horizon { position:absolute; bottom:0; left:0; right:0; height:2px; background:linear-gradient(90deg,transparent,var(--color-orange),transparent); }
  .sun-icon { position:absolute; font-size:2.5rem; filter:drop-shadow(0 0 12px rgba(255,200,0,0.4)); animation:sun-glow 2s ease-in-out infinite; }
  @keyframes sun-glow { 0%,100%{transform:translate(-50%,-50%) scale(1)} 50%{transform:translate(-50%,-50%) scale(1.12)} }
  .sun-time { position:absolute; bottom:0; font-size:0.7rem; font-weight:800; color:var(--color-sub); text-align:center; }

  /* Temp curve */
  .curve-svg { width:100%; height:180px; }
  .now-dot { animation: dot-pulse 2s ease-in-out infinite; }
  @keyframes dot-pulse { 0%,100%{r:5;opacity:1} 50%{r:8;opacity:0.7} }
  .now-line { animation: line-fade 2s ease-in-out infinite; }
  @keyframes line-fade { 0%,100%{opacity:0.5} 50%{opacity:0.2} }

  /* AQI bar */
  .aqi-bar { width:0; transition: width 1.5s cubic-bezier(0.34,1.56,0.64,1); }

  /* Forecast */
  .fc-card { transition: all 0.3s; }
  .fc-card:hover { transform: translateY(-6px) scale(1.04); box-shadow: 0 12px 24px rgba(0,0,0,0.2); border-color: var(--color-gold) !important; }
  .fc-card:hover .fc-emoji { animation: fc-pop 0.4s ease; }
  @keyframes fc-pop { 0%{transform:scale(1)} 40%{transform:scale(1.3) rotate(10deg)} 100%{transform:scale(1.1)} }

  /* Map */
  .leaflet-container { background: var(--color-bg) !important; border-radius: 1rem; }
  .leaflet-control-zoom { display: none !important; }
  .leaflet-control-attribution { font-size: 0.55rem !important; opacity: 0.4; }
  .map-pulse {
    width:18px; height:18px; border-radius:50%; background:var(--color-pink);
    box-shadow: 0 0 0 0 rgba(244,114,182,0.6);
    animation: pulse 2s infinite;
  }
  @keyframes pulse { 0%{box-shadow:0 0 0 0 rgba(244,114,182,0.6)} 70%{box-shadow:0 0 0 18px rgba(244,114,182,0)} 100%{box-shadow:0 0 0 0 rgba(244,114,182,0)} }
</style>

<script>
  const wEmoji: Record<string,string> = {
    '01d':'☀️','01n':'🌙','02d':'⛅','02n':'☁️','03d':'☁️','03n':'☁️',
    '04d':'☁️','04n':'☁️','09d':'🌧️','09n':'🌧️','10d':'🌦️','10n':'🌧️',
    '11d':'⛈️','11n':'⛈️','13d':'🌨️','13n':'🌨️','50d':'🌫️','50n':'🌫️'
  };

  const aqiLevels = [
    { label:'좋음', emoji:'😊', color:'text-green', bg:'bg-green/10', comment:'공기 좋아! 마스크 불필요 ✨' },
    { label:'보통', emoji:'🙂', color:'text-blue', bg:'bg-blue/10', comment:'대체로 괜찮아. 민감하면 주의' },
    { label:'나쁨', emoji:'😷', color:'text-orange', bg:'bg-orange/10', comment:'마스크 챙기세요 ⚠️' },
    { label:'매우 나쁨', emoji:'🤮', color:'text-red', bg:'bg-red/10', comment:'외출 자제! 🏠' },
    { label:'위험', emoji:'☠️', color:'text-purple', bg:'bg-purple/10', comment:'절대 밖에 나가지 마세요' },
  ];

  const dayNames = ['일','월','화','수','목','금','토'];

  interface Loc { lat:number; lon:number; source:string; label:string; }

  async function getLoc(): Promise<Loc> {
    try {
      const p = await new Promise<GeolocationPosition>((ok,no) => {
        if (!navigator.geolocation) { no(new Error('x')); return; }
        navigator.geolocation.getCurrentPosition(ok, no, {timeout:5000,maximumAge:300000});
      });
      return {lat:p.coords.latitude,lon:p.coords.longitude,source:'gps',label:'GPS 위치'};
    } catch {}
    try {
      const r = await fetch('http://ip-api.com/json/?fields=lat,lon,city,regionName',{signal:AbortSignal.timeout(4000)});
      if (r.ok) { const d = await r.json(); if (d.lat&&d.lon) return {lat:d.lat,lon:d.lon,source:'ip',label:`IP (${d.city||d.regionName||'?'})`}; }
    } catch {}
    return {lat:37.5665,lon:126.978,source:'fallback',label:'서울 (기본)'};
  }

  function fmtTime(iso: string): string {
    const d = new Date(iso);
    return d.toLocaleTimeString('ko-KR',{hour:'2-digit',minute:'2-digit',hour12:false});
  }

  function sunPos(sunrise: string, sunset: string): number {
    const now = Date.now();
    const rise = new Date(sunrise).getTime();
    const set = new Date(sunset).getTime();
    if (now < rise) return 0;
    if (now > set) return 1;
    return (now - rise) / (set - rise);
  }

  function initMap(lat:number, lon:number) {
    if (typeof (window as any).L==='undefined') return;
    const L = (window as any).L;
    const m = L.map('map',{zoomControl:false,attributionControl:true,dragging:true,scrollWheelZoom:false}).setView([lat,lon],14);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png',{
      attribution:'&copy; OSM', subdomains:'abcd', maxZoom:19
    }).addTo(m);
    L.marker([lat,lon],{icon:L.divIcon({className:'',html:'<div class="map-pulse"></div>',iconSize:[18,18],iconAnchor:[9,9]})}).addTo(m);
  }

  function barColor(r:number):string { return r<0.3?'bg-green':r<0.6?'bg-blue':r<0.8?'bg-orange':'bg-red'; }
  function barText(r:number):string { return r<0.3?'text-green':r<0.6?'text-blue':r<0.8?'text-orange':'text-red'; }

  async function init() {
    const loc = await getLoc();
    const navLoc = document.getElementById('nav-loc');
    if (navLoc) navLoc.textContent = `📍 ${loc.label}`;
    initMap(loc.lat, loc.lon);

    try {
      const res = await fetch(`https://api.aurore.work/weather?lat=${loc.lat}&lon=${loc.lon}`);
      if (!res.ok) throw new Error(`${res.status}`);
      render(await res.json());
    } catch (e:any) {
      const c = document.getElementById('content');
      if (c) c.innerHTML = `<div class="bg-card border border-border rounded-2xl p-8 text-center"><div class="text-5xl mb-3">😵</div><div class="text-lg font-black text-sub">날씨 로드 실패</div><div class="text-sm text-dim mt-1">${e.message}</div></div>`;
    }
  }

  function render(data: any) {
    const c = document.getElementById('content');
    if (!c) return;
    const cur = data.current;
    const emoji = wEmoji[cur.icon]||'🌡️';
    const aqiIdx = data.aqi?.index||1;
    const aqi = aqiLevels[aqiIdx-1]||aqiLevels[0];
    const comp = data.aqi?.components||{};
    const forecast = data.forecast||[];
    const ws = data.weekendSummary;

    // --- Sun arc ---
    let sunHtml = '';
    if (cur.sunrise && cur.sunset) {
      const pos = sunPos(cur.sunrise, cur.sunset);
      const isDay = pos > 0 && pos < 1;
      const angle = Math.PI * (1 - pos);
      const sx = 50 + 42 * Math.cos(angle);
      const sy = 95 - 85 * Math.sin(angle);
      const riseMs = new Date(cur.sunrise).getTime();
      const setMs = new Date(cur.sunset).getTime();
      const dayLen = setMs - riseMs;
      const dayH = Math.floor(dayLen/3600000);
      const dayM = Math.round((dayLen%3600000)/60000);

      sunHtml = `
        <div class="bg-card border border-border rounded-2xl p-5 mb-5">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-sm font-black text-sub">🌅 일출 · 일몰</h3>
            <span class="text-xs font-bold text-dim">${isDay ? `☀️ 낮 ${dayH}시간 ${dayM}분` : '🌙 밤'}</span>
          </div>
          <div class="sun-arc">
            <div class="sun-arc-track"></div>
            <div class="sun-arc-horizon"></div>
            <div class="sun-icon" style="left:${sx}%;top:${sy}%">${isDay?'☀️':(pos>=1?'🌙':'🌅')}</div>
            <div class="sun-time" style="left:5%"><div class="text-xl mb-0.5">🌅</div>${fmtTime(cur.sunrise)}</div>
            <div class="sun-time" style="right:5%;text-align:right"><div class="text-xl mb-0.5">🌇</div>${fmtTime(cur.sunset)}</div>
          </div>
          <div class="flex justify-center gap-4 mt-3">
            <span class="text-xs font-bold px-3 py-1 rounded-full bg-orange/10 text-orange">🌅 ${fmtTime(cur.sunrise)}</span>
            <span class="text-xs font-bold px-3 py-1 rounded-full bg-purple/10 text-purple">🌇 ${fmtTime(cur.sunset)}</span>
          </div>
        </div>`;
    }

    // --- Temp curve ---
    const f0 = forecast[0];
    const tMin = f0?.low ?? (cur.temp_min || cur.temp - 3);
    const tMax = f0?.high ?? (cur.temp_max || cur.temp + 3);
    const nowH = new Date().getHours() + new Date().getMinutes()/60;

    function tAt(h:number):number {
      if (h>=6&&h<=15) { const s=((h-6)/9); return tMin+(tMax-tMin)*(1-Math.cos(s*Math.PI))/2; }
      else { const s=h>15?(h-15)/15:(h+9)/15; return tMax-(tMax-tMin)*(1-Math.cos(s*Math.PI))/2; }
    }

    const pts:{h:number;t:number}[] = [];
    for(let h=0;h<24;h++) pts.push({h,t:Math.floor(nowH)===h?cur.temp:Math.round(tAt(h)*10)/10});

    const W=600,H=150,px=40,py=20,cw=W-px*2,ch=H-py*2;
    const ts=pts.map(p=>p.t); const mn=Math.min(...ts)-1,mx=Math.max(...ts)+1,rng=mx-mn||1;
    const toXY=(h:number,t:number):[number,number]=>[px+(h/23)*cw, py+(1-(t-mn)/rng)*ch];

    const svgPts=pts.map(p=>toXY(p.h,p.t));
    let path=`M${svgPts[0][0]},${svgPts[0][1]}`;
    for(let i=0;i<svgPts.length-1;i++){
      const a=svgPts[Math.max(0,i-1)],b=svgPts[i],c=svgPts[i+1],d=svgPts[Math.min(svgPts.length-1,i+2)];
      path+=` C${b[0]+(c[0]-a[0])/6},${b[1]+(c[1]-a[1])/6} ${c[0]-(d[0]-b[0])/6},${c[1]-(d[1]-b[1])/6} ${c[0]},${c[1]}`;
    }
    const fill=path+` L${svgPts[svgPts.length-1][0]},${py+ch} L${svgPts[0][0]},${py+ch} Z`;
    const [nx,ny]=toXY(nowH,cur.temp);

    const grid:string[]=[];
    const step=rng>8?3:rng>4?2:1;
    for(let t=Math.ceil(mn);t<=Math.floor(mx);t+=step){
      const[,y]=toXY(0,t);
      grid.push(`<line x1="${px}" y1="${y}" x2="${W-px}" y2="${y}" stroke="var(--color-border)" stroke-width="0.8" stroke-dasharray="3,3"/><text x="${px-4}" y="${y+3}" text-anchor="end" fill="var(--color-dim)" font-size="9" font-weight="700">${t}°</text>`);
    }
    const tLabels=[0,3,6,9,12,15,18,21].map(h=>`<text x="${toXY(h,0)[0]}" y="${H-2}" text-anchor="middle" fill="var(--color-dim)" font-size="9" font-weight="700">${h}시</text>`).join('');

    const curveSvg=`<svg viewBox="0 0 ${W} ${H}" class="curve-svg" preserveAspectRatio="xMidYMid meet">
      <defs><linearGradient id="cg" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="var(--color-gold)" stop-opacity="0.25"/><stop offset="100%" stop-color="var(--color-gold)" stop-opacity="0.02"/></linearGradient></defs>
      ${grid.join('')}
      <path d="${fill}" fill="url(#cg)"/>
      <path d="${path}" fill="none" stroke="var(--color-gold)" stroke-width="2" stroke-linecap="round"/>
      ${tLabels}
      <line x1="${nx}" y1="${py}" x2="${nx}" y2="${py+ch}" stroke="var(--color-pink)" stroke-width="1.5" stroke-dasharray="3,3" class="now-line"/>
      <circle cx="${nx}" cy="${ny}" r="5" fill="var(--color-pink)" class="now-dot"/>
      <text x="${nx}" y="${ny-12}" text-anchor="middle" fill="var(--color-pink)" font-size="12" font-weight="900">${Math.round(cur.temp)}°</text>
      <text x="${nx}" y="${py-4}" text-anchor="middle" fill="var(--color-pink)" font-size="8" font-weight="800">지금</text>
    </svg>`;

    // --- Pollutants ---
    const polls = [
      {name:'PM2.5',val:comp.pm2_5||0,max:75},{name:'PM10',val:comp.pm10||0,max:150},
      {name:'O₃',val:comp.o3||0,max:180},{name:'NO₂',val:comp.no2||0,max:200},{name:'CO',val:comp.co||0,max:15000},
    ];

    // --- Weekend ---
    let wsHtml = '';
    if (ws?.days?.length) {
      wsHtml = `
        <div class="bg-card border border-border rounded-2xl p-5 mb-5">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-2xl w-bounce">${ws.allGood?'🎉':'🌂'}</span>
            <h3 class="text-sm font-black text-sub">이번 주말</h3>
          </div>
          <div class="grid grid-cols-${ws.days.length} gap-3 mb-3">
            ${ws.days.map((d:any)=>`
              <div class="bg-bg rounded-xl p-3 text-center">
                <div class="text-xs font-black ${d.dayOfWeek===0||d.dayOfWeek===6?'text-pink':'text-sub'}">${typeof d.dayOfWeek==='number'?dayNames[d.dayOfWeek]:d.dayOfWeek}</div>
                <div class="text-2xl my-1.5">${wEmoji[d.icon]||'🌡️'}</div>
                <div class="text-sm font-black"><span class="text-orange">${d.high}°</span> / <span class="text-blue">${d.low}°</span></div>
                <div class="text-[0.65rem] text-dim">${d.description}</div>
              </div>
            `).join('')}
          </div>
          <div class="text-xs font-bold text-sub bg-bg rounded-lg px-3 py-2 text-center">${ws.recommendation||''}</div>
        </div>`;
    }

    // --- Forecast day names ---
    const fDayName = (dow:number) => dayNames[dow] || '';

    c.innerHTML = `
      <!-- HERO: Current Weather -->
      <div class="bg-card border border-border rounded-2xl p-6 sm:p-8 mb-5 relative overflow-hidden">
        <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-8">
          <div class="text-7xl sm:text-8xl w-bounce shrink-0">${emoji}</div>
          <div class="text-center sm:text-left flex-1">
            <div class="hero-temp">${Math.round(cur.temp)}°</div>
            <div class="text-lg font-black text-sub mt-1">${cur.description}</div>
            <div class="text-sm text-dim font-bold mt-0.5">체감 ${Math.round(cur.feels_like)}° · ${cur.name}</div>
          </div>
          <div class="grid grid-cols-2 gap-2 shrink-0 text-center">
            <div class="m-card bg-bg rounded-xl px-4 py-3">
              <div class="text-xl font-black text-blue">${cur.humidity}%</div>
              <div class="text-[0.6rem] font-bold text-dim">💧 습도</div>
            </div>
            <div class="m-card bg-bg rounded-xl px-4 py-3">
              <div class="text-xl font-black text-cyan">${cur.wind}<span class="text-xs">m/s</span></div>
              <div class="text-[0.6rem] font-bold text-dim">🌬️ 바람</div>
            </div>
            <div class="m-card bg-bg rounded-xl px-4 py-3">
              <div class="text-xl font-black text-purple">${cur.clouds}%</div>
              <div class="text-[0.6rem] font-bold text-dim">☁️ 구름</div>
            </div>
            <div class="m-card bg-bg rounded-xl px-4 py-3">
              <div class="text-xl font-black text-orange">${cur.visibility ? Math.round(cur.visibility/1000) : '-'}<span class="text-xs">km</span></div>
              <div class="text-[0.6rem] font-bold text-dim">👁️ 가시</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Temp Curve -->
      <div class="bg-card border border-border rounded-2xl p-5 mb-5">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-sm font-black text-sub">🌡️ 하루 기온 변화</h3>
          <div class="flex gap-3 text-xs font-bold text-dim">
            <span>최저 <span class="text-blue font-black">${tMin}°</span></span>
            <span>최고 <span class="text-orange font-black">${tMax}°</span></span>
          </div>
        </div>
        ${curveSvg}
      </div>

      <!-- Sun Arc -->
      ${sunHtml}

      <!-- AQI -->
      <div class="bg-card border border-border rounded-2xl p-5 mb-5">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-3xl w-bounce">${aqi.emoji}</span>
          <div>
            <div class="text-lg font-black ${aqi.color}">${aqi.label}</div>
            <div class="text-xs text-dim font-bold">${data.aqi?.comment || aqi.comment}</div>
          </div>
        </div>
        <div class="grid grid-cols-5 gap-2">
          ${polls.map(p=>{
            const r=Math.min(p.val/p.max,1);
            return `<div class="text-center">
              <div class="text-[0.65rem] text-dim font-bold">${p.name}</div>
              <div class="text-sm font-black ${barText(r)}">${Math.round(p.val)}</div>
              <div class="w-full h-1.5 bg-bg rounded-full mt-1 overflow-hidden"><div class="h-full rounded-full aqi-bar ${barColor(r)}" data-w="${r*100}%"></div></div>
            </div>`;
          }).join('')}
        </div>
      </div>

      <!-- Weekend -->
      ${wsHtml}

      <!-- 5-Day Forecast -->
      <h3 class="text-lg font-black text-text mb-3">📅 5일 예보</h3>
      <div class="grid grid-cols-5 gap-2 mb-6">
        ${forecast.map((d:any,i:number)=>`
          <div class="fc-card bg-card border ${d.isWeekend?'border-pink/30':'border-border'} rounded-xl p-3 text-center">
            <div class="text-xs font-black ${d.isWeekend?'text-pink':'text-sub'}">${typeof d.dayOfWeek==='number'?fDayName(d.dayOfWeek):d.dayOfWeek}</div>
            <div class="text-[0.6rem] font-mono text-dim">${d.date?.slice(5)||''}</div>
            <div class="text-3xl my-2 fc-emoji">${wEmoji[d.icon]||'🌡️'}</div>
            <div class="text-sm font-black"><span class="text-orange">${d.high}°</span><span class="text-dim mx-0.5">/</span><span class="text-blue">${d.low}°</span></div>
            <div class="text-[0.6rem] text-dim font-bold mt-0.5">${d.description}</div>
            ${d.pop>0?`<div class="text-[0.6rem] text-blue font-bold mt-0.5">💧${d.pop}%</div>`:''}
          </div>
        `).join('')}
      </div>
    `;

    // Animate AQI bars
    requestAnimationFrame(()=>{
      setTimeout(()=>{
        document.querySelectorAll('.aqi-bar').forEach(b=>{
          (b as HTMLElement).style.width=(b as HTMLElement).dataset.w||'0%';
        });
      },300);
    });
  }

  init();
</script>
