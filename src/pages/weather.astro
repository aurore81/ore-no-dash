---
import Base from '../layouts/Base.astro';
---

<Base title="날씨" active="weather">
  <!-- Location indicator -->
  <div class="flex items-center justify-end mb-4">
    <span id="nav-loc" class="text-xs font-mono text-dim">위치 확인 중...</span>
  </div>

  <!-- Content area -->
  <div id="content">
    <div class="text-center py-16">
      <div class="text-6xl mb-4 animate-spin">🌀</div>
      <p class="text-lg font-bold text-dim">날씨 데이터를 가져오는 중...</p>
    </div>
  </div>

  <!-- Footer -->
  <footer class="text-center py-4 text-xs text-dim mt-8">
    aurore.work // Weather API
  </footer>
</Base>

<script>
  // --- Weather emoji map ---
  const weatherEmoji: Record<string, string> = {
    '01d':'☀️','01n':'🌙','02d':'⛅','02n':'☁️','03d':'☁️','03n':'☁️',
    '04d':'☁️','04n':'☁️','09d':'🌧️','09n':'🌧️','10d':'🌦️','10n':'🌧️',
    '11d':'⛈️','11n':'⛈️','13d':'🌨️','13n':'🌨️','50d':'🌫️','50n':'🌫️'
  };

  // --- AQI levels ---
  const aqiLevels = [
    { label: '좋음', emoji: '😊', colorClass: 'text-green', bgClass: 'bg-green/10', comment: '마음껏 밖에서 놀아도 돼!' },
    { label: '보통', emoji: '🙂', colorClass: 'text-blue', bgClass: 'bg-blue/10', comment: '대체로 괜찮아. 민감군은 주의.' },
    { label: '나쁨', emoji: '😷', colorClass: 'text-orange', bgClass: 'bg-orange/10', comment: '마스크 쓰고 나가자!' },
    { label: '매우 나쁨', emoji: '🤮', colorClass: 'text-red', bgClass: 'bg-red/10', comment: '외출 자제! 집에서 쉬자.' },
    { label: '위험', emoji: '☠️', colorClass: 'text-purple', bgClass: 'bg-purple/10', comment: '밖에 나가지 마!!' },
  ];

  // --- 3-tier location ---
  interface LocResult {
    lat: number;
    lon: number;
    source: string;
    label: string;
  }

  async function getLocation(): Promise<LocResult> {
    // Tier 1: Browser Geolocation
    try {
      const pos = await new Promise<GeolocationPosition>((resolve, reject) => {
        if (!navigator.geolocation) { reject(new Error('no geo')); return; }
        navigator.geolocation.getCurrentPosition(resolve, reject, { timeout: 5000, maximumAge: 300000 });
      });
      return { lat: pos.coords.latitude, lon: pos.coords.longitude, source: 'gps', label: 'GPS' };
    } catch {}

    // Tier 2: IP geolocation (ip-api.com — HTTP only for free tier)
    try {
      const res = await fetch('http://ip-api.com/json/?fields=lat,lon,city,regionName', { signal: AbortSignal.timeout(4000) });
      if (res.ok) {
        const data = await res.json();
        if (data.lat && data.lon) {
          return { lat: data.lat, lon: data.lon, source: 'ip', label: `IP (${data.city || data.regionName || '알 수 없음'})` };
        }
      }
    } catch {}

    // Tier 3: Fallback Seoul
    return { lat: 37.5665, lon: 126.978, source: 'fallback', label: '서울 (기본)' };
  }

  // --- Bar color helper ---
  function barColorClass(ratio: number): string {
    if (ratio < 0.3) return 'bg-green';
    if (ratio < 0.6) return 'bg-blue';
    if (ratio < 0.8) return 'bg-orange';
    return 'bg-red';
  }

  function barTextClass(ratio: number): string {
    if (ratio < 0.3) return 'text-green';
    if (ratio < 0.6) return 'text-blue';
    if (ratio < 0.8) return 'text-orange';
    return 'text-red';
  }

  // --- Sunrise/sunset formatter ---
  function formatUnixTime(unix: number): string {
    const d = new Date(unix * 1000);
    return d.toLocaleTimeString('ko-KR', { hour: '2-digit', minute: '2-digit', hour12: false });
  }

  // --- Init ---
  async function init() {
    const loc = await getLocation();
    const navLoc = document.getElementById('nav-loc');
    if (navLoc) navLoc.textContent = `📍 ${loc.label}`;

    try {
      const apiUrl = `https://api.aurore.work/weather?lat=${loc.lat}&lon=${loc.lon}`;
      const res = await fetch(apiUrl);
      if (!res.ok) throw new Error(`API error: ${res.status}`);
      const data = await res.json();
      render(data);
    } catch (err: any) {
      showError(err.message || '날씨 데이터를 가져올 수 없습니다.');
    }
  }

  function render(data: any) {
    const content = document.getElementById('content');
    if (!content) return;

    const cur = data.current;
    const emoji = weatherEmoji[cur.icon] || '🌡️';
    const aqiIndex = data.aqi?.index || 1;
    const aqi = aqiLevels[aqiIndex - 1] || aqiLevels[0];
    const components = data.aqi?.components || {};
    const forecast = data.forecast || [];
    const ws = data.weekendSummary;

    // Pollutants
    const pollutants = [
      { name: 'PM2.5', val: components.pm2_5 || 0, max: 75 },
      { name: 'PM10', val: components.pm10 || 0, max: 150 },
      { name: 'O3', val: components.o3 || 0, max: 180 },
      { name: 'NO2', val: components.no2 || 0, max: 200 },
      { name: 'CO', val: components.co || 0, max: 15000 },
    ];

    content.innerHTML = `
      <!-- Current Weather: BIG -->
      <div class="bg-card border border-border rounded-2xl p-8 mb-6">
        <div class="flex flex-col sm:flex-row items-center gap-6">
          <div class="text-8xl shrink-0">${emoji}</div>
          <div class="text-center sm:text-left">
            <div class="text-7xl font-black text-text leading-none">${Math.round(cur.temp)}°</div>
            <div class="text-xl font-bold text-sub capitalize mt-1">${cur.description}</div>
            <div class="text-sm text-dim mt-1">체감 ${Math.round(cur.feels_like)}° · ${cur.name}</div>
          </div>
        </div>

        <!-- Key metrics -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-6">
          <div class="bg-bg rounded-xl p-4 text-center">
            <div class="text-3xl font-black text-blue">${cur.humidity}%</div>
            <div class="text-xs font-bold text-dim uppercase mt-1">습도</div>
          </div>
          <div class="bg-bg rounded-xl p-4 text-center">
            <div class="text-3xl font-black text-cyan">${cur.wind}m/s</div>
            <div class="text-xs font-bold text-dim uppercase mt-1">바람</div>
          </div>
          <div class="bg-bg rounded-xl p-4 text-center">
            <div class="text-3xl font-black text-purple">${cur.clouds}%</div>
            <div class="text-xs font-bold text-dim uppercase mt-1">구름</div>
          </div>
          <div class="bg-bg rounded-xl p-4 text-center">
            <div class="text-3xl font-black text-orange">${cur.rain || 0}mm</div>
            <div class="text-xs font-bold text-dim uppercase mt-1">강수</div>
          </div>
        </div>

        <!-- Sunrise / Sunset -->
        ${cur.sunrise && cur.sunset ? `
        <div class="flex justify-center gap-8 mt-4 text-sm font-bold text-sub">
          <span>🌅 ${formatUnixTime(cur.sunrise)}</span>
          <span>🌇 ${formatUnixTime(cur.sunset)}</span>
        </div>
        ` : ''}
      </div>

      <!-- Air Quality -->
      <div class="bg-card border border-border rounded-2xl p-6 mb-6 text-center">
        <h3 class="text-sm font-extrabold text-sub mb-4">🌬️ 대기질</h3>
        <div class="inline-flex items-center gap-4 px-6 py-4 rounded-2xl ${aqi.bgClass}">
          <span class="text-5xl">${aqi.emoji}</span>
          <div class="text-left">
            <div class="text-2xl font-black ${aqi.colorClass}">${aqi.label}</div>
            <div class="text-sm font-semibold text-sub">${aqi.comment}</div>
          </div>
        </div>

        <!-- Pollutant bars -->
        <div class="flex gap-4 mt-5 justify-center flex-wrap">
          ${pollutants.map(p => {
            const ratio = Math.min(p.val / p.max, 1);
            return `
              <div class="text-center min-w-[60px]">
                <div class="text-[0.65rem] text-dim font-bold mb-1">${p.name}</div>
                <div class="text-sm font-extrabold ${barTextClass(ratio)}">${Math.round(p.val)}</div>
                <div class="w-full h-1.5 bg-bg rounded-full mt-1 overflow-hidden">
                  <div class="h-full rounded-full ${barColorClass(ratio)} transition-all duration-700" style="width:${ratio * 100}%"></div>
                </div>
              </div>
            `;
          }).join('')}
        </div>
      </div>

      <!-- Weekend Summary -->
      ${ws ? `
      <div class="bg-card border border-pink/20 rounded-2xl p-6 mb-6 text-center">
        <div class="text-4xl mb-2">${ws.allGood ? '🎉' : '🌂'}</div>
        <h3 class="text-xl font-black text-pink mb-2">이번 주말은?</h3>
        <div class="text-sm text-sub leading-relaxed">
          ${ws.days?.map((d: any) => `${d.dayOfWeek}: ${weatherEmoji[d.icon] || '🌡️'} ${d.description}, ${d.low}~${d.high}°C${d.pop > 30 ? ` (비 ${d.pop}%)` : ''}`).join(' / ') || ''}
          <div class="font-bold mt-1">${ws.recommendation || ''}</div>
        </div>
      </div>
      ` : ''}

      <!-- 5-day Forecast -->
      <h3 class="text-2xl font-black mb-4 text-text">📅 5일 예보</h3>
      <div class="grid grid-cols-3 sm:grid-cols-5 gap-3 mb-8">
        ${forecast.map((d: any) => `
          <div class="bg-card border ${d.isWeekend ? 'border-pink/40' : 'border-border'} rounded-2xl p-4 text-center hover:-translate-y-1 transition-all">
            <div class="text-sm font-extrabold ${d.isWeekend ? 'text-pink' : 'text-sub'}">${d.dayOfWeek}</div>
            <div class="text-xs font-mono text-dim">${d.date?.slice(5) || ''}</div>
            <div class="text-3xl my-2">${weatherEmoji[d.icon] || '🌡️'}</div>
            <div class="text-sm font-extrabold">
              <span class="text-orange">${d.high}°</span>
              <span class="text-dim">/</span>
              <span class="text-blue">${d.low}°</span>
            </div>
            <div class="text-xs text-dim capitalize mt-0.5">${d.description}</div>
            ${d.pop > 0 ? `<div class="text-xs text-blue font-bold mt-1">💧 ${d.pop}%</div>` : ''}
          </div>
        `).join('')}
      </div>
    `;
  }

  function showError(msg: string) {
    const content = document.getElementById('content');
    if (!content) return;
    content.innerHTML = `
      <div class="bg-card border border-border rounded-2xl p-8 text-center">
        <div class="text-5xl mb-4">😵</div>
        <div class="text-lg font-bold text-sub mb-2">${msg}</div>
        <div class="text-xs font-mono text-dim">잠시 후 다시 시도해주세요.</div>
      </div>
    `;
  }

  // Expose formatUnixTime to template literals
  (window as any).__formatUnixTime = formatUnixTime;

  init();
</script>
