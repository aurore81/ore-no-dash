<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>WEATHER // aurore.work</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=JetBrains+Mono:wght@400;600;700&display=swap');

    :root {
      --bg: #f0f4ff;
      --bg2: #e5edff;
      --card: #ffffff;
      --card-hover: #f8faff;
      --border: #d5ddf0;
      --text: #1e1e2e;
      --text-sub: #555568;
      --text-dim: #999aaa;
      --purple: #7c5cfc;
      --pink: #ff6b9d;
      --blue: #4a9eff;
      --green: #2ecf7a;
      --orange: #ff8c42;
      --yellow: #ffc107;
      --red: #ff5252;
      --cyan: #00c4b4;
      --shadow: 0 2px 16px rgba(74,158,255,0.08);
      --shadow-hover: 0 8px 30px rgba(74,158,255,0.12);
      --mono: 'JetBrains Mono', monospace;
      --body: 'Nunito', sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--body); background: var(--bg); color: var(--text); min-height: 100vh; }

    .container { max-width: 900px; margin: 0 auto; padding: 1.5rem; }

    .nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
    .nav-back {
      font-family: var(--mono); font-size: 0.75rem; color: var(--text-dim);
      text-decoration: none; padding: 0.4rem 0.8rem; border-radius: 10px;
      border: 1px solid var(--border); transition: all 0.2s; font-weight: 600;
    }
    .nav-back:hover { color: var(--blue); border-color: var(--blue); }
    .nav-loc { font-family: var(--mono); font-size: 0.7rem; color: var(--text-dim); }

    .header { text-align: center; margin-bottom: 2rem; }
    .header-emoji { font-size: 4rem; display: block; margin-bottom: 0.3rem; animation: bounce 2s ease-in-out infinite; }
    @keyframes bounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
    .header h1 {
      font-size: 2rem; font-weight: 900;
      background: linear-gradient(135deg, var(--blue), var(--cyan), var(--green));
      background-size: 200% 200%; animation: grad 4s ease infinite;
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    @keyframes grad { 0%,100%{background-position:0% 50%} 50%{background-position:100% 50%} }
    .header-sub { font-size: 0.85rem; color: var(--text-dim); font-weight: 700; margin-top: 0.2rem; }

    /* LOADING */
    .loading { text-align: center; padding: 3rem; color: var(--text-dim); font-size: 1.2rem; font-weight: 700; }
    .loading .spinner { font-size: 3rem; animation: spin 1s linear infinite; display: inline-block; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ERROR */
    .error-box { text-align: center; padding: 2rem; background: var(--card); border-radius: 16px; border: 1px solid var(--border); }
    .error-box .icon { font-size: 3rem; margin-bottom: 0.5rem; }
    .error-box .msg { color: var(--text-sub); font-size: 0.9rem; margin-bottom: 1rem; }
    .error-box .hint { font-family: var(--mono); font-size: 0.7rem; color: var(--text-dim); }

    /* NOW CARD */
    .now-card {
      background: var(--card); border: 1px solid var(--border); border-radius: 20px;
      padding: 2rem; box-shadow: var(--shadow); margin-bottom: 1.5rem;
      display: flex; align-items: center; gap: 2rem; flex-wrap: wrap;
    }
    .now-icon { font-size: 5rem; flex-shrink: 0; filter: drop-shadow(0 4px 8px rgba(0,0,0,0.1)); }
    .now-temp { font-size: 4rem; font-weight: 900; line-height: 1; }
    .now-desc { font-size: 1.1rem; font-weight: 700; color: var(--text-sub); text-transform: capitalize; }
    .now-feels { font-size: 0.8rem; color: var(--text-dim); margin-top: 0.2rem; }
    .now-details {
      display: flex; gap: 1rem; margin-left: auto; flex-wrap: wrap;
    }
    .now-detail {
      text-align: center; padding: 0.5rem 0.8rem;
      background: var(--bg); border-radius: 12px; min-width: 70px;
    }
    .now-detail-val { font-size: 1rem; font-weight: 800; color: var(--blue); }
    .now-detail-label { font-size: 0.6rem; color: var(--text-dim); font-weight: 700; text-transform: uppercase; }

    /* AIR QUALITY */
    .aqi-card {
      background: var(--card); border: 1px solid var(--border); border-radius: 20px;
      padding: 1.5rem; box-shadow: var(--shadow); margin-bottom: 1.5rem;
      text-align: center;
    }
    .aqi-title { font-size: 0.85rem; font-weight: 800; color: var(--text-sub); margin-bottom: 0.8rem; }
    .aqi-grade {
      display: inline-flex; align-items: center; gap: 0.8rem;
      padding: 0.8rem 2rem; border-radius: 16px; font-size: 1.2rem; font-weight: 900;
    }
    .aqi-emoji { font-size: 2.5rem; }
    .aqi-text { text-align: left; }
    .aqi-level { font-size: 1.1rem; }
    .aqi-comment { font-size: 0.75rem; font-weight: 600; opacity: 0.8; }
    .aqi-bars {
      display: flex; gap: 0.8rem; margin-top: 1rem; justify-content: center; flex-wrap: wrap;
    }
    .aqi-bar-item { text-align: center; min-width: 60px; }
    .aqi-bar-name { font-size: 0.6rem; color: var(--text-dim); font-weight: 700; margin-bottom: 0.3rem; }
    .aqi-bar-val { font-size: 0.85rem; font-weight: 800; }
    .aqi-bar-track { width: 100%; height: 6px; background: var(--bg2); border-radius: 3px; margin-top: 0.2rem; overflow: hidden; }
    .aqi-bar-fill { height: 100%; border-radius: 3px; transition: width 0.8s ease; }

    /* FORECAST */
    .section-title { font-size: 1rem; font-weight: 800; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }
    .forecast-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
      gap: 0.6rem; margin-bottom: 1.5rem;
    }
    .fc-card {
      background: var(--card); border: 1px solid var(--border); border-radius: 14px;
      padding: 0.8rem; text-align: center; box-shadow: var(--shadow);
      transition: all 0.2s;
    }
    .fc-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-hover); }
    .fc-card.weekend { border-color: var(--pink); background: rgba(255,107,157,0.03); }
    .fc-day { font-size: 0.75rem; font-weight: 800; color: var(--text-sub); }
    .fc-card.weekend .fc-day { color: var(--pink); }
    .fc-date { font-family: var(--mono); font-size: 0.6rem; color: var(--text-dim); }
    .fc-icon { font-size: 2rem; margin: 0.3rem 0; }
    .fc-temps { font-size: 0.85rem; font-weight: 800; }
    .fc-high { color: var(--orange); }
    .fc-low { color: var(--blue); }
    .fc-desc { font-size: 0.65rem; color: var(--text-dim); text-transform: capitalize; }
    .fc-rain { font-size: 0.6rem; color: var(--blue); font-weight: 700; margin-top: 0.2rem; }

    /* WEEKEND HIGHLIGHT */
    .weekend-box {
      background: linear-gradient(135deg, rgba(255,107,157,0.06), rgba(124,92,252,0.06));
      border: 1px solid rgba(255,107,157,0.15); border-radius: 20px;
      padding: 1.5rem; text-align: center; margin-bottom: 1.5rem;
    }
    .weekend-title { font-size: 1.1rem; font-weight: 900; color: var(--pink); margin-bottom: 0.5rem; }
    .weekend-summary { font-size: 0.9rem; color: var(--text-sub); line-height: 1.6; }
    .weekend-emoji { font-size: 2rem; margin-bottom: 0.3rem; display: block; }

    /* FUN MSG */
    .fun-msg {
      text-align: center; padding: 1rem; font-size: 0.85rem; font-weight: 700;
      color: var(--text-sub); margin-bottom: 1rem;
      background: var(--card); border-radius: 16px; border: 1px solid var(--border);
    }

    .footer { text-align: center; margin-top: 2rem; padding: 1rem 0; font-size: 0.65rem; color: var(--text-dim); }

    @media (max-width: 640px) {
      .container { padding: 0.8rem; }
      .now-card { padding: 1.2rem; gap: 1rem; }
      .now-icon { font-size: 3.5rem; }
      .now-temp { font-size: 2.8rem; }
      .now-details { margin-left: 0; width: 100%; justify-content: center; }
      .forecast-grid { grid-template-columns: repeat(3, 1fr); }
    }
  </style>
</head>
<body>

<div class="container">
  <div class="nav">
    <a href="/" class="nav-back">← HOME</a>
    <div class="nav-loc" id="nav-loc">위치 확인 중...</div>
  </div>

  <div class="header">
    <span class="header-emoji" id="header-emoji">🌤️</span>
    <h1>Weather</h1>
    <div class="header-sub">실시간 날씨 + 미세먼지 + 주말 예보</div>
  </div>

  <div id="content">
    <div class="loading" id="loading">
      <div class="spinner">🌀</div>
      <div style="margin-top:0.5rem;">날씨 데이터를 가져오는 중...</div>
    </div>
  </div>

  <div class="footer">aurore.work // OpenWeatherMap API</div>
</div>

<script>
const OWM_KEY = 'OWM_API_KEY_HERE';

const weatherEmoji = {
  '01d':'☀️','01n':'🌙','02d':'⛅','02n':'☁️','03d':'☁️','03n':'☁️',
  '04d':'☁️','04n':'☁️','09d':'🌧️','09n':'🌧️','10d':'🌦️','10n':'🌧️',
  '11d':'⛈️','11n':'⛈️','13d':'🌨️','13n':'🌨️','50d':'🌫️','50n':'🌫️'
};

const aqiData = [
  { level: 1, label: '좋음', emoji: '😊', color: '#2ecf7a', bg: 'rgba(46,207,122,0.1)', comment: '마음껏 밖에서 놀아도 돼!' },
  { level: 2, label: '보통', emoji: '🙂', color: '#4a9eff', bg: 'rgba(74,158,255,0.1)', comment: '대체로 괜찮아. 민감군은 주의.' },
  { level: 3, label: '나쁨', emoji: '😷', color: '#ff8c42', bg: 'rgba(255,140,66,0.1)', comment: '마스크 쓰고 나가자!' },
  { level: 4, label: '매우 나쁨', emoji: '🤮', color: '#ff5252', bg: 'rgba(255,82,82,0.1)', comment: '외출 자제! 집에서 쉬자.' },
  { level: 5, label: '위험', emoji: '☠️', color: '#7c5cfc', bg: 'rgba(124,92,252,0.1)', comment: '밖에 나가지 마!!' },
];

const funMessages = {
  clear: ['완벽한 날씨! 밖에 나가서 햇볕 쬐자 ☀️', '이런 날 코딩하면 효율 200% 🚀', '하늘이 반짝반짝! 오늘 뭐 할 거야? ✨'],
  clouds: ['구름이 많지만 나쁘지 않아 ☁️', '흐린 날은 카페에서 코딩이지 💻', '구름 사이로 빛이 들어올 거야 🌤️'],
  rain: ['우산 챙겨! 비 오는 날 코딩이 최고야 🌧️', '빗소리 들으면서 집중 모드 ON 🎧', '비 와도 코드는 멈추지 않는다 💪'],
  snow: ['눈이다!! 눈사람 만들자 ⛄', '눈 오는 날의 따뜻한 코딩 타임 ☕', '겨울왕국 모드 활성화 ❄️'],
  thunderstorm: ['번개 치는 날! 집에서 안전하게 코딩 ⚡', '천둥 BGM 들으면서 개발 중 🎵'],
  default: ['오늘도 화이팅! 💪', '좋은 하루 보내자 ✨']
};

function getFunMsg(weatherMain) {
  const key = weatherMain.toLowerCase();
  const msgs = funMessages[key] || funMessages.default;
  return msgs[Math.floor(Math.random() * msgs.length)];
}

async function init() {
  if (OWM_KEY === 'OWM_API_KEY_HERE') {
    showApiKeyNeeded();
    return;
  }

  try {
    const pos = await getLocation();
    const { lat, lon } = pos;
    document.getElementById('nav-loc').textContent = `📍 ${lat.toFixed(2)}, ${lon.toFixed(2)}`;

    const [weather, forecast, air] = await Promise.all([
      fetch(`https://api.openweathermap.org/data/2.5/weather?lat=${lat}&lon=${lon}&appid=${OWM_KEY}&units=metric&lang=kr`).then(r => r.json()),
      fetch(`https://api.openweathermap.org/data/2.5/forecast?lat=${lat}&lon=${lon}&appid=${OWM_KEY}&units=metric&lang=kr`).then(r => r.json()),
      fetch(`https://api.openweathermap.org/data/2.5/air_pollution?lat=${lat}&lon=${lon}&appid=${OWM_KEY}`).then(r => r.json()),
    ]);

    render(weather, forecast, air);
  } catch (err) {
    showError(err.message);
  }
}

function getLocation() {
  return new Promise((resolve, reject) => {
    if (!navigator.geolocation) {
      reject(new Error('위치 서비스를 지원하지 않는 브라우저입니다.'));
      return;
    }
    navigator.geolocation.getCurrentPosition(
      p => resolve({ lat: p.coords.latitude, lon: p.coords.longitude }),
      () => {
        // Fallback: Seoul
        resolve({ lat: 37.5665, lon: 126.978 });
      },
      { timeout: 5000 }
    );
  });
}

function render(weather, forecast, air) {
  const content = document.getElementById('content');
  const icon = weather.weather[0].icon;
  const emoji = weatherEmoji[icon] || '🌡️';
  document.getElementById('header-emoji').textContent = emoji;

  // Process 5-day forecast (group by date, get min/max)
  const dailyMap = {};
  forecast.list.forEach(item => {
    const date = item.dt_txt.split(' ')[0];
    if (!dailyMap[date]) dailyMap[date] = { temps: [], icons: [], descs: [], rain: 0, pops: [] };
    dailyMap[date].temps.push(item.main.temp_min, item.main.temp_max);
    dailyMap[date].icons.push(item.weather[0].icon);
    dailyMap[date].descs.push(item.weather[0].description);
    dailyMap[date].pops.push(item.pop || 0);
    if (item.rain) dailyMap[date].rain += item.rain['3h'] || 0;
    if (item.snow) dailyMap[date].rain += item.snow['3h'] || 0;
  });

  const days = Object.entries(dailyMap).slice(0, 5).map(([date, data]) => {
    const d = new Date(date);
    const dayNames = ['일','월','화','수','목','금','토'];
    const isWeekend = d.getDay() === 0 || d.getDay() === 6;
    // Pick most common daytime icon
    const dayIcons = data.icons.filter(i => i.endsWith('d'));
    const mainIcon = dayIcons.length ? dayIcons[Math.floor(dayIcons.length/2)] : data.icons[0];
    return {
      date, day: dayNames[d.getDay()],
      dateStr: `${d.getMonth()+1}/${d.getDate()}`,
      high: Math.round(Math.max(...data.temps)),
      low: Math.round(Math.min(...data.temps)),
      icon: weatherEmoji[mainIcon] || '🌡️',
      desc: data.descs[Math.floor(data.descs.length/2)],
      rain: Math.round(data.rain * 10) / 10,
      pop: Math.round(Math.max(...data.pops) * 100),
      isWeekend
    };
  });

  // AQI
  const aqiIndex = air.list[0].main.aqi;
  const aqiInfo = aqiData[aqiIndex - 1] || aqiData[0];
  const components = air.list[0].components;

  // Weekend summary
  const weekendDays = days.filter(d => d.isWeekend);
  let weekendHtml = '';
  if (weekendDays.length > 0) {
    const summary = weekendDays.map(d => `${d.day}요일: ${d.icon} ${d.desc}, ${d.low}~${d.high}°C${d.pop > 30 ? ` (비 ${d.pop}%)` : ''}`).join(' / ');
    const allGood = weekendDays.every(d => d.pop < 40);
    const weekendEmoji = allGood ? '🎉' : '🌂';
    const weekendComment = allGood
      ? '주말 날씨 좋아! 나들이 가자!'
      : '우산 준비하고 실내 계획도 세워두자!';
    weekendHtml = `
      <div class="weekend-box">
        <span class="weekend-emoji">${weekendEmoji}</span>
        <div class="weekend-title">이번 주말은?</div>
        <div class="weekend-summary">${summary}<br><strong>${weekendComment}</strong></div>
      </div>
    `;
  }

  // Pollutant bars
  const pollutants = [
    { name: 'PM2.5', val: components.pm2_5, max: 75, unit: 'ug/m3' },
    { name: 'PM10', val: components.pm10, max: 150, unit: 'ug/m3' },
    { name: 'O3', val: components.o3, max: 180, unit: 'ug/m3' },
    { name: 'NO2', val: components.no2, max: 200, unit: 'ug/m3' },
    { name: 'CO', val: components.co, max: 15000, unit: 'ug/m3' },
  ];

  function barColor(ratio) {
    if (ratio < 0.3) return 'var(--green)';
    if (ratio < 0.6) return 'var(--blue)';
    if (ratio < 0.8) return 'var(--orange)';
    return 'var(--red)';
  }

  content.innerHTML = `
    <div class="fun-msg">${getFunMsg(weather.weather[0].main)}</div>

    <div class="now-card">
      <div class="now-icon">${emoji}</div>
      <div>
        <div class="now-temp">${Math.round(weather.main.temp)}°</div>
        <div class="now-desc">${weather.weather[0].description}</div>
        <div class="now-feels">체감 ${Math.round(weather.main.feels_like)}° · ${weather.name}</div>
      </div>
      <div class="now-details">
        <div class="now-detail"><div class="now-detail-val">${weather.main.humidity}%</div><div class="now-detail-label">습도</div></div>
        <div class="now-detail"><div class="now-detail-val">${weather.wind.speed}m/s</div><div class="now-detail-label">바람</div></div>
        <div class="now-detail"><div class="now-detail-val">${weather.clouds.all}%</div><div class="now-detail-label">구름</div></div>
        ${weather.rain ? `<div class="now-detail"><div class="now-detail-val">${weather.rain['1h'] || 0}mm</div><div class="now-detail-label">강수</div></div>` : ''}
      </div>
    </div>

    <div class="aqi-card">
      <div class="aqi-title">🌬️ 대기질 / 미세먼지</div>
      <div class="aqi-grade" style="background:${aqiInfo.bg};color:${aqiInfo.color}">
        <span class="aqi-emoji">${aqiInfo.emoji}</span>
        <div class="aqi-text">
          <div class="aqi-level">${aqiInfo.label}</div>
          <div class="aqi-comment">${aqiInfo.comment}</div>
        </div>
      </div>
      <div class="aqi-bars">
        ${pollutants.map(p => {
          const ratio = Math.min(p.val / p.max, 1);
          return `<div class="aqi-bar-item">
            <div class="aqi-bar-name">${p.name}</div>
            <div class="aqi-bar-val" style="color:${barColor(ratio)}">${Math.round(p.val)}</div>
            <div class="aqi-bar-track"><div class="aqi-bar-fill" style="width:${ratio*100}%;background:${barColor(ratio)}"></div></div>
          </div>`;
        }).join('')}
      </div>
    </div>

    ${weekendHtml}

    <div class="section-title">📅 5일 예보</div>
    <div class="forecast-grid">
      ${days.map(d => `
        <div class="fc-card${d.isWeekend ? ' weekend' : ''}">
          <div class="fc-day">${d.day}</div>
          <div class="fc-date">${d.dateStr}</div>
          <div class="fc-icon">${d.icon}</div>
          <div class="fc-temps"><span class="fc-high">${d.high}°</span> / <span class="fc-low">${d.low}°</span></div>
          <div class="fc-desc">${d.desc}</div>
          ${d.pop > 0 ? `<div class="fc-rain">💧 ${d.pop}%</div>` : ''}
        </div>
      `).join('')}
    </div>
  `;
}

function showApiKeyNeeded() {
  document.getElementById('content').innerHTML = `
    <div class="error-box">
      <div class="icon">🔑</div>
      <div class="msg">OpenWeatherMap API 키가 필요합니다</div>
      <div class="hint">
        1. <a href="https://openweathermap.org/api" target="_blank">openweathermap.org</a>에서 무료 가입<br>
        2. API Keys에서 키 복사<br>
        3. weather.html의 OWM_KEY에 붙여넣기
      </div>
    </div>
  `;
}

function showError(msg) {
  document.getElementById('content').innerHTML = `
    <div class="error-box">
      <div class="icon">😵</div>
      <div class="msg">${msg}</div>
      <div class="hint">잠시 후 다시 시도해주세요.</div>
    </div>
  `;
}

init();
</script>
</body>
</html>
