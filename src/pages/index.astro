---
import Base from '../layouts/Base.astro';
---

<Base title="홈" active="home">
  <!-- JoJo menacing -->
  <div class="menacing" style="right:5%;top:15%">ゴゴゴ</div>
  <div class="menacing" style="left:3%;top:40%">ドドド</div>
  <div class="menacing" style="right:8%;bottom:25%">ゴゴゴ</div>

  <!-- Speed lines -->
  <div class="speed-lines" id="speed-lines"></div>

  <!-- Floating particles -->
  <div class="particles" id="particles"></div>

  <!-- Anime mascot (CSS art) -->
  <div class="anime-mascot" id="mascot">
    <div class="mascot-body">
      <div class="mascot-face">
        <div class="mascot-eye left"></div>
        <div class="mascot-eye right"></div>
        <div class="mascot-mouth"></div>
        <div class="mascot-blush left"></div>
        <div class="mascot-blush right"></div>
      </div>
      <div class="mascot-ear left"></div>
      <div class="mascot-ear right"></div>
    </div>
    <div class="mascot-speech" id="mascot-speech">ようこそ！✨</div>
  </div>

  <!-- Combo counter -->
  <div class="combo" id="combo">
    <div class="combo-count" id="combo-count">0</div>
    <div class="text-xs font-bold text-sub uppercase tracking-widest">COMBO! ✨</div>
  </div>

  <!-- Deploy counter -->
  <div class="bg-card border-2 border-border rounded-2xl p-5 mb-6 flex items-center justify-between flex-wrap gap-4 relative overflow-hidden deploy-card">
    <div class="deploy-shine"></div>
    <div class="flex items-center gap-4 relative z-1">
      <div class="text-4xl deploy-emoji" id="deploy-emoji">🚀</div>
      <div>
        <div class="text-xs font-bold text-dim uppercase tracking-widest">Deployments</div>
        <div class="flex items-baseline gap-2">
          <span class="text-4xl font-black text-gold tabular-nums" id="deploy-count">-</span>
          <span class="text-sm font-bold text-sub">회 배포</span>
        </div>
      </div>
    </div>
    <div class="text-right relative z-1">
      <div class="text-xs font-mono text-dim" id="deploy-last">마지막 배포: 확인 중...</div>
      <div class="text-xs font-bold text-green mt-1" id="deploy-status"></div>
    </div>
  </div>

  <!-- Greeting banner -->
  <div class="greeting-banner" id="greeting">
    <div class="greeting-shine"></div>
    <span class="relative z-1"></span>
  </div>

  <!-- Filter pills -->
  <div class="flex justify-center gap-2 mb-6 flex-wrap" id="filters">
    <button class="filter-pill active" data-filter="all">🌈 전체</button>
    <button class="filter-pill" data-filter="infra">⚙️ 인프라</button>
    <button class="filter-pill" data-filter="media">🎵 미디어</button>
    <button class="filter-pill" data-filter="dev">💻 개발</button>
  </div>

  <!-- Service cards grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-12" id="services"></div>

  <!-- History section -->
  <div class="mb-12">
    <h2 class="text-2xl font-black mb-6 text-text">📜 작업 히스토리</h2>
    <div id="history"></div>
  </div>

  <!-- Footer: device status -->
  <footer class="flex justify-center gap-6 flex-wrap py-6 border-t border-border">
    <div class="flex items-center gap-2 text-sm font-bold text-sub">
      <span class="dot"></span> NAS DS720+
    </div>
    <div class="flex items-center gap-2 text-sm font-bold text-sub">
      <span class="dot"></span> Mac Studio
    </div>
    <div class="flex items-center gap-2 text-sm font-bold text-sub">
      <span class="dot"></span> M1 mini
    </div>
    <div class="flex items-center gap-2 text-sm font-bold text-sub">
      <span class="dot"></span> ER7206
    </div>
  </footer>
</Base>

<style is:inline>
  /* === MENACING TEXT (JoJo) === */
  .menacing {
    position: fixed;
    font-size: 1.8rem;
    color: var(--color-accent);
    opacity: 0;
    font-weight: 900;
    font-style: italic;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
    animation: menacing 3s ease-in-out infinite;
    z-index: 0;
    pointer-events: none;
  }
  .menacing:nth-child(1) { animation-delay: 0s; }
  .menacing:nth-child(2) { animation-delay: 1s; }
  .menacing:nth-child(3) { animation-delay: 2s; }
  @keyframes menacing {
    0%,100% { opacity: 0; transform: translateY(0) scale(0.8); }
    20% { opacity: 0.5; transform: translateY(-10px) scale(1); }
    40% { opacity: 0; transform: translateY(-20px) scale(1.1); }
  }

  /* === SPEED LINES === */
  .speed-lines {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    pointer-events: none; z-index: 0; overflow: hidden; opacity: 0.03;
  }
  .speed-line {
    position: absolute; background: var(--color-accent); transform-origin: center;
  }

  /* === FLOATING PARTICLES === */
  .particles {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    pointer-events: none; z-index: 0; overflow: hidden;
  }
  .particle {
    position: absolute; opacity: 0.2;
    animation: float linear infinite;
  }
  @keyframes float {
    0% { transform: translateY(100vh) rotate(0deg) scale(1); }
    50% { transform: translateY(50vh) rotate(180deg) scale(1.3); }
    100% { transform: translateY(-10vh) rotate(360deg) scale(1); }
  }

  /* === SPARKLE CLICK === */
  .sparkle {
    position: fixed; pointer-events: none; z-index: 999;
    font-size: 1.5rem;
    animation: sparkle-pop 0.6s ease-out forwards;
  }
  @keyframes sparkle-pop {
    0% { transform: scale(0) rotate(0deg); opacity: 1; }
    50% { transform: scale(1.5) rotate(180deg); opacity: 1; }
    100% { transform: scale(0) rotate(360deg); opacity: 0; }
  }

  /* === COMBO COUNTER === */
  .combo {
    position: fixed; top: 20px; right: 20px; z-index: 100;
    text-align: right; pointer-events: none;
    opacity: 0; transition: opacity 0.3s;
  }
  .combo.show { opacity: 1; }
  .combo-count {
    font-size: 3rem; font-weight: 900;
    color: var(--color-gold);
    text-shadow: 0 0 20px color-mix(in srgb, var(--color-gold) 50%, transparent), 2px 2px 0 rgba(0,0,0,0.3);
    line-height: 1;
  }
  .combo-count.anime-hit { animation: combo-hit 0.3s ease; }
  @keyframes combo-hit {
    0% { transform: scale(1); } 50% { transform: scale(1.5); } 100% { transform: scale(1); }
  }

  /* === ANIME REACTION === */
  .reaction {
    position: fixed; z-index: 1000; font-size: 3rem;
    pointer-events: none;
    animation: reaction-pop 1s ease-out forwards;
  }
  @keyframes reaction-pop {
    0% { transform: scale(0) translateY(0); opacity: 1; }
    30% { transform: scale(1.5) translateY(-20px); opacity: 1; }
    100% { transform: scale(0.5) translateY(-80px); opacity: 0; }
  }

  /* === GREETING BANNER === */
  .greeting-banner {
    text-align: center; padding: 1rem 1.5rem; margin-bottom: 1.5rem;
    background: linear-gradient(135deg, color-mix(in srgb, var(--color-gold) 8%, transparent), color-mix(in srgb, var(--color-pink) 8%, transparent));
    border-radius: 20px;
    border: 2px solid color-mix(in srgb, var(--color-gold) 15%, transparent);
    font-size: 1.1rem; font-weight: 700; color: var(--color-gold);
    position: relative; overflow: hidden;
  }
  .greeting-shine {
    position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
    background: linear-gradient(45deg, transparent 40%, rgba(255,255,255,0.04) 50%, transparent 60%);
    animation: shine 3s infinite;
  }
  @keyframes shine {
    0% { transform: translateX(-100%) rotate(45deg); }
    100% { transform: translateX(100%) rotate(45deg); }
  }

  /* === DEPLOY CARD === */
  .deploy-card { transition: all 0.3s; }
  .deploy-card:hover { transform: translateY(-2px); border-color: color-mix(in srgb, var(--color-gold) 30%, transparent); }
  .deploy-shine {
    position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
    background: linear-gradient(45deg, transparent 40%, rgba(255,215,0,0.03) 50%, transparent 60%);
    animation: shine 4s infinite;
  }
  .deploy-emoji { animation: anime-bounce 2s ease-in-out infinite; }
  @keyframes anime-bounce {
    0%,100% { transform: translateY(0) scale(1); }
    30% { transform: translateY(-8px) scale(1.1); }
  }

  /* === ANIME CARD === */
  .anime-card {
    position: relative; overflow: hidden;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .anime-card::before {
    content: '';
    position: absolute; top: 50%; left: 50%; width: 0; height: 0;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-gold) 15%, transparent) 0%, transparent 70%);
    border-radius: 50%; transition: all 0.4s ease;
    transform: translate(-50%, -50%); z-index: 0;
  }
  .anime-card:hover::before { width: 300%; height: 300%; }
  .anime-card::after {
    content: attr(data-sfx);
    position: absolute; top: 8px; right: 12px;
    font-size: 0.7rem; font-weight: 900;
    color: var(--color-gold); opacity: 0;
    transform: scale(0) rotate(-15deg);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    z-index: 2;
  }
  .anime-card:hover::after { opacity: 1; transform: scale(1) rotate(-5deg); }
  .anime-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 15px 40px rgba(0,0,0,0.3), 0 0 20px color-mix(in srgb, var(--color-gold) 5%, transparent);
    border-color: color-mix(in srgb, var(--color-gold) 30%, transparent);
  }
  .anime-card:hover .card-icon-inner { animation: icon-anime 0.5s ease; }
  @keyframes icon-anime {
    0% { transform: scale(1) rotate(0); }
    25% { transform: scale(1.3) rotate(-10deg); }
    50% { transform: scale(0.9) rotate(5deg); }
    100% { transform: scale(1.1) rotate(0); }
  }
  @keyframes card-in {
    from { opacity: 0; transform: translateY(30px) scale(0.9); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* === FILTER PILLS === */
  .filter-pill {
    padding: 0.5rem 1.2rem; border-radius: 9999px;
    font-size: 0.85rem; font-weight: 700; cursor: pointer;
    border: 2px solid transparent;
    background: var(--color-card); color: var(--color-sub);
    transition: all 0.3s; position: relative; overflow: hidden;
  }
  .filter-pill:hover {
    background: var(--color-card-hover); color: var(--color-text);
    transform: scale(1.05);
  }
  .filter-pill:active { animation: btn-smash 0.3s ease; }
  @keyframes btn-smash { 0%{transform:scale(1.05)} 50%{transform:scale(0.9)} 100%{transform:scale(1.05)} }
  .filter-pill.active {
    border-color: var(--color-gold);
    color: var(--color-gold);
    background: color-mix(in srgb, var(--color-gold) 10%, transparent);
    box-shadow: 0 0 15px color-mix(in srgb, var(--color-gold) 20%, transparent);
  }

  /* === STATUS DOT === */
  .dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--color-green);
    box-shadow: 0 0 10px color-mix(in srgb, var(--color-green) 50%, transparent);
    animation: pulse 2s ease-in-out infinite; display: inline-block;
  }
  @keyframes pulse {
    0%,100% { opacity: 1; } 50% { opacity: 0.5; }
  }

  /* === ANIME MASCOT (CSS Art) === */
  .anime-mascot {
    position: fixed; bottom: 20px; left: 20px; z-index: 50;
    cursor: pointer; transition: transform 0.3s;
    animation: mascot-float 4s ease-in-out infinite;
  }
  .anime-mascot:hover { transform: scale(1.15) rotate(-5deg); }
  .anime-mascot:hover .mascot-speech { opacity: 1; transform: translateY(-5px) scale(1); }
  @keyframes mascot-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  .mascot-body {
    width: 60px; height: 60px; border-radius: 50%;
    background: linear-gradient(135deg, var(--color-pink), var(--color-purple));
    position: relative;
    box-shadow: 0 5px 20px color-mix(in srgb, var(--color-pink) 40%, transparent);
  }
  .mascot-face { position: absolute; inset: 0; }
  .mascot-eye {
    position: absolute; top: 35%; width: 8px; height: 10px;
    background: white; border-radius: 50%;
    animation: mascot-blink 4s ease infinite;
  }
  .mascot-eye.left { left: 30%; }
  .mascot-eye.right { right: 30%; }
  .mascot-eye::after {
    content: ''; position: absolute; top: 2px; left: 2px;
    width: 4px; height: 5px; background: #333; border-radius: 50%;
  }
  @keyframes mascot-blink {
    0%, 45%, 55%, 100% { transform: scaleY(1); }
    50% { transform: scaleY(0.1); }
  }
  .mascot-mouth {
    position: absolute; bottom: 28%; left: 50%; transform: translateX(-50%);
    width: 12px; height: 6px; border-bottom: 3px solid white;
    border-radius: 0 0 50% 50%;
  }
  .mascot-blush {
    position: absolute; top: 48%; width: 10px; height: 6px;
    background: color-mix(in srgb, var(--color-pink) 60%, transparent);
    border-radius: 50%; opacity: 0.7;
  }
  .mascot-blush.left { left: 12%; }
  .mascot-blush.right { right: 12%; }
  .mascot-ear {
    position: absolute; top: -8px; width: 16px; height: 20px;
    background: linear-gradient(135deg, var(--color-pink), var(--color-purple));
    border-radius: 50% 50% 0 0;
  }
  .mascot-ear.left { left: 8px; transform: rotate(-15deg); }
  .mascot-ear.right { right: 8px; transform: rotate(15deg); }
  .mascot-ear::after {
    content: ''; position: absolute; top: 3px; left: 3px; right: 3px; height: 10px;
    background: color-mix(in srgb, var(--color-pink) 80%, white);
    border-radius: 50% 50% 0 0;
  }
  .mascot-speech {
    position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%) translateY(-5px) scale(0.8);
    background: var(--color-card); border: 2px solid var(--color-gold);
    border-radius: 12px; padding: 6px 12px; white-space: nowrap;
    font-size: 0.75rem; font-weight: 800; color: var(--color-gold);
    opacity: 0; transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    margin-bottom: 8px;
  }
  .mascot-speech::after {
    content: ''; position: absolute; top: 100%; left: 50%; transform: translateX(-50%);
    border: 6px solid transparent; border-top-color: var(--color-gold);
  }

  @media (max-width: 640px) {
    .menacing { display: none; }
    .combo { top: 10px; right: 10px; }
    .combo-count { font-size: 2rem; }
    .anime-mascot { bottom: 10px; left: 10px; }
    .mascot-body { width: 45px; height: 45px; }
  }
</style>

<script>
  // --- Anime SFX & Reactions ---
  const sfxList = ['ドン！', 'バーン！', 'キター！', 'ズバッ！', 'ワクワク', 'スゴイ！', 'ヨシ！', 'イクゾ！', 'ナイス！'];
  const reactions = ['(≧▽≦)', '(ﾉ◕ヮ◕)ﾉ✧', '(☆▽☆)', 'ヽ(>∀<☆)ノ', '(*≧ω≦)', '(ノ´ヮ`)ノ*:・゚✧', '٩(◕‿◕｡)۶'];

  // --- Greeting ---
  const greetings: Record<string, string[]> = {
    morning: ['좋은 아침이에요! おはよう～☀️', '오늘도 화이팅! ファイト！💪', '커피 한 잔 어때요? ☕ いただきます！'],
    afternoon: ['좋은 오후에요! こんにちは～🌤️', '점심은 드셨나요? 🍱 もぐもぐ', '오후도 파이팅! がんばれ！✨'],
    evening: ['좋은 저녁이에요! こんばんは～🌙', '오늘 하루 수고했어요! お疲れ様！💜', '맛있는 저녁 드세요! 🍽️ うまい！'],
    night: ['아직 안 자요? まだ起きてる？🦉', '푹 자요～ おやすみ！🌙', '오늘도 수고했어요! お疲れ様でした！💤'],
  };
  const h = new Date().getHours();
  const period = h >= 6 && h < 12 ? 'morning' : h < 18 ? 'afternoon' : h < 23 ? 'evening' : 'night';
  const msgs = greetings[period];
  const greetEl = document.getElementById('greeting');
  if (greetEl) {
    const span = greetEl.querySelector('span');
    if (span) span.textContent = msgs[Math.floor(Math.random() * msgs.length)];
  }

  // --- Theme particles ---
  const themeParticles: Record<string, string[]> = {
    morning: ['🌸', '☀️', '🌤️', '🐦', '🌻', '☕', '🍞', '🌈', '🦋', '✨'],
    afternoon: ['⚡', '💻', '☁️', '🚀', '💡', '🎯', '📱', '🎮', '✨', '🌊'],
    evening: ['🌅', '🌇', '🍷', '💜', '🌆', '🎵', '🦊', '🔮', '✨', '🌙'],
    night: ['✨', '💜', '🌙', '⭐', '💫', '🔮', '🦋', '🌸', '⚡', '🎌'],
  };

  // --- Speed lines ---
  const slContainer = document.getElementById('speed-lines');
  if (slContainer) {
    for (let i = 0; i < 30; i++) {
      const line = document.createElement('div');
      line.className = 'speed-line';
      line.style.left = Math.random() * 100 + '%';
      line.style.top = Math.random() * 100 + '%';
      line.style.width = (50 + Math.random() * 150) + 'px';
      line.style.height = '1px';
      line.style.transform = `rotate(${Math.random() * 360}deg)`;
      slContainer.appendChild(line);
    }
  }

  // --- Particles ---
  const emojis = themeParticles[period] || themeParticles.night;
  const pContainer = document.getElementById('particles');
  if (pContainer) {
    for (let i = 0; i < 18; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      p.textContent = emojis[Math.floor(Math.random() * emojis.length)];
      p.style.left = Math.random() * 100 + '%';
      p.style.animationDuration = (12 + Math.random() * 18) + 's';
      p.style.animationDelay = (-Math.random() * 20) + 's';
      p.style.fontSize = (0.8 + Math.random() * 1) + 'rem';
      pContainer.appendChild(p);
    }
  }

  // --- Sparkle click ---
  document.addEventListener('click', (e) => {
    for (let i = 0; i < 5; i++) {
      const sparkle = document.createElement('div');
      sparkle.className = 'sparkle';
      sparkle.textContent = ['✦', '✧', '⚡', '★', '✿'][Math.floor(Math.random() * 5)];
      sparkle.style.left = (e.clientX + (Math.random() - 0.5) * 60) + 'px';
      sparkle.style.top = (e.clientY + (Math.random() - 0.5) * 60) + 'px';
      sparkle.style.color = ['var(--color-gold)', 'var(--color-pink)', 'var(--color-blue)', 'var(--color-purple)', 'var(--color-green)'][Math.floor(Math.random() * 5)];
      document.body.appendChild(sparkle);
      setTimeout(() => sparkle.remove(), 600);
    }
  });

  // --- Combo counter ---
  let combo = 0;
  let comboTimer: ReturnType<typeof setTimeout> | null = null;
  const comboEl = document.getElementById('combo');
  const comboCountEl = document.getElementById('combo-count');

  function addCombo(e?: MouseEvent) {
    combo++;
    if (comboCountEl) {
      comboCountEl.textContent = combo.toString();
      comboCountEl.classList.remove('anime-hit');
      void comboCountEl.offsetWidth;
      comboCountEl.classList.add('anime-hit');
    }
    comboEl?.classList.add('show');

    if (combo % 5 === 0) {
      const r = document.createElement('div');
      r.className = 'reaction';
      r.textContent = reactions[Math.floor(Math.random() * reactions.length)];
      r.style.left = (e ? e.clientX : window.innerWidth / 2) - 30 + 'px';
      r.style.top = (e ? e.clientY : window.innerHeight / 2) + 'px';
      r.style.color = ['var(--color-gold)', 'var(--color-pink)', 'var(--color-blue)'][Math.floor(Math.random() * 3)];
      document.body.appendChild(r);
      setTimeout(() => r.remove(), 1000);
    }

    if (comboTimer) clearTimeout(comboTimer);
    comboTimer = setTimeout(() => { combo = 0; comboEl?.classList.remove('show'); }, 3000);
  }

  // --- Types ---
  interface Service { name: string; domain: string; icon: string; description: string; route: string; category: string; }
  interface HistoryEntry { type: string; title: string; desc: string; }
  interface HistoryDay { date: string; entries: HistoryEntry[]; }

  const catColors: Record<string, { bg: string; text: string; iconBg: string }> = {
    infra: { bg: 'bg-orange/10', text: 'text-orange', iconBg: 'bg-orange/20' },
    media: { bg: 'bg-pink/10', text: 'text-pink', iconBg: 'bg-pink/20' },
    dev:   { bg: 'bg-blue/10', text: 'text-blue', iconBg: 'bg-blue/20' },
  };
  const catLabels: Record<string, string> = { infra: '인프라', media: '미디어', dev: '개발' };
  const badgeStyles: Record<string, { bg: string; text: string; label: string }> = {
    add:    { bg: 'bg-green/15', text: 'text-green', label: 'NEW' },
    fix:    { bg: 'bg-blue/15', text: 'text-blue', label: 'FIX' },
    remove: { bg: 'bg-red/15', text: 'text-red', label: 'DEL' },
    change: { bg: 'bg-orange/15', text: 'text-orange', label: 'CHG' },
  };

  // --- Gate token ---
  const GATE_KEY = 'e3087205509900d6c862f806ccd58d1d';
  async function hmacToken(): Promise<string> {
    const enc = new TextEncoder();
    const ts = Math.floor(Date.now() / 30000).toString();
    const key = await crypto.subtle.importKey('raw', enc.encode(GATE_KEY), { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']);
    const sig = await crypto.subtle.sign('HMAC', key, enc.encode(ts));
    return `?t=${Array.from(new Uint8Array(sig)).map(b => b.toString(16).padStart(2, '0')).join('').slice(0, 16)}&ts=${ts}`;
  }

  // --- Render services ---
  function renderServices(services: Service[], filter = 'all') {
    const grid = document.getElementById('services');
    if (!grid) return;
    grid.innerHTML = '';
    const filtered = filter === 'all' ? services : services.filter(s => s.category === filter);

    filtered.forEach((s, i) => {
      const c = catColors[s.category] || catColors.infra;
      const proto = s.domain.startsWith('ftp.') ? 'ftp' : 'https';
      const href = s.domain.startsWith('ssh.') ? '#' : `${proto}://${s.domain}`;
      const isGated = s.domain.startsWith('max.') || s.domain.startsWith('claude.');

      const card = document.createElement('a');
      card.href = href;
      card.target = s.domain.startsWith('ssh.') ? '_self' : '_blank';
      card.rel = 'noopener';
      card.className = 'anime-card bg-card border-2 border-border rounded-2xl p-6 block';
      card.style.animation = `card-in 0.5s ease ${i * 0.05}s both`;
      card.setAttribute('data-sfx', sfxList[i % sfxList.length]);
      if (isGated) card.dataset.gated = '1';

      card.addEventListener('mouseenter', (e) => addCombo(e));

      card.innerHTML = `
        <div class="flex items-center gap-4 mb-3 relative z-1">
          <div class="card-icon-inner text-4xl w-14 h-14 flex items-center justify-center rounded-xl ${c.iconBg} shrink-0">${s.icon}</div>
          <div class="min-w-0">
            <div class="text-xl font-black text-text truncate">${s.name}</div>
            <div class="text-xs font-mono text-cyan truncate">${s.domain}</div>
          </div>
        </div>
        <p class="text-sub text-sm leading-relaxed mb-3 relative z-1">${s.description}</p>
        <div class="flex items-center justify-between relative z-1">
          <span class="text-xs font-mono text-dim truncate max-w-[65%]">${s.route}</span>
          <span class="text-xs font-extrabold px-2.5 py-0.5 rounded-full ${c.bg} ${c.text}">${catLabels[s.category]}</span>
        </div>
      `;

      grid.appendChild(card);
    });
  }

  // --- Render history ---
  function renderHistory(days: HistoryDay[]) {
    const container = document.getElementById('history');
    if (!container) return;
    container.innerHTML = '';

    days.forEach((day, di) => {
      const dayEl = document.createElement('div');
      dayEl.className = 'mb-6';
      dayEl.style.animation = `card-in 0.4s ease ${di * 0.1}s both`;

      const dateHeader = document.createElement('div');
      dateHeader.className = 'text-sm font-black text-gold mb-3 pl-3 border-l-3 border-gold';
      dateHeader.textContent = day.date;
      dayEl.appendChild(dateHeader);

      day.entries.forEach(entry => {
        const badge = badgeStyles[entry.type] || badgeStyles.change;
        const item = document.createElement('div');
        item.className = 'bg-card border border-border rounded-xl px-4 py-3 mb-2 flex items-start gap-3 hover:border-gold/20 transition-all hover:translate-x-1';
        item.innerHTML = `
          <span class="text-[0.65rem] font-extrabold px-2 py-0.5 rounded-full ${badge.bg} ${badge.text} shrink-0 mt-0.5">${badge.label}</span>
          <div class="min-w-0">
            <div class="text-sm font-bold text-text">${entry.title}</div>
            <div class="text-xs text-dim leading-relaxed">${entry.desc}</div>
          </div>
        `;
        dayEl.appendChild(item);
      });

      container.appendChild(dayEl);
    });
  }

  // --- Filter pills ---
  function setupFilters(services: Service[]) {
    document.querySelectorAll('.filter-pill').forEach(btn => {
      btn.addEventListener('click', (e) => {
        document.querySelectorAll('.filter-pill').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        renderServices(services, (btn as HTMLElement).dataset.filter || 'all');
        addCombo(e as MouseEvent);
      });
    });
  }

  // --- Gate click handler ---
  document.addEventListener('click', async (e) => {
    const a = (e.target as HTMLElement).closest('a[data-gated]');
    if (!a) return;
    e.preventDefault();
    const href = a.getAttribute('href');
    if (!href) return;
    window.open(href + await hmacToken(), '_blank');
  });

  // --- Deploy counter ---
  function animateCount(el: HTMLElement, target: number) {
    const duration = 1200;
    const start = performance.now();
    const ease = (t: number) => t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
    function tick(now: number) {
      const progress = Math.min((now - start) / duration, 1);
      el.textContent = Math.round(ease(progress) * target).toLocaleString();
      if (progress < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  function timeAgo(date: Date): string {
    const s = Math.floor((Date.now() - date.getTime()) / 1000);
    if (s < 60) return '방금 전';
    const m = Math.floor(s / 60);
    if (m < 60) return `${m}분 전`;
    const hr = Math.floor(m / 60);
    if (hr < 24) return `${hr}시간 전`;
    return `${Math.floor(hr / 24)}일 전`;
  }

  function renderDeployCounter(data: any) {
    const countEl = document.getElementById('deploy-count');
    const lastEl = document.getElementById('deploy-last');
    const statusEl = document.getElementById('deploy-status');
    const emojiEl = document.getElementById('deploy-emoji');
    if (!countEl || !data) return;

    animateCount(countEl, data.total);

    if (lastEl && data.lastDeployedAt) lastEl.textContent = `마지막 배포: ${timeAgo(new Date(data.lastDeployedAt))}`;
    if (statusEl) {
      statusEl.textContent = data.lastStatus === 'success' ? '● 정상 가동 中' : '○ 상태 確認 必要';
      statusEl.className = data.lastStatus === 'success' ? 'text-xs font-bold text-green mt-1' : 'text-xs font-bold text-orange mt-1';
    }
    if (emojiEl) {
      const t = data.total;
      emojiEl.textContent = t >= 100 ? '🏆' : t >= 50 ? '🔥' : t >= 20 ? '⚡' : t >= 10 ? '🚀' : '🌱';
    }
  }

  // --- Konami code ---
  const konamiCode = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
  let konamiIndex = 0;
  document.addEventListener('keydown', (e) => {
    if (e.key === konamiCode[konamiIndex]) {
      konamiIndex++;
      if (konamiIndex === konamiCode.length) {
        document.documentElement.style.animation = 'rainbow 5s linear infinite';
        konamiIndex = 0;
        for (let i = 0; i < 10; i++) {
          setTimeout(() => {
            const r = document.createElement('div');
            r.className = 'reaction';
            r.textContent = reactions[Math.floor(Math.random() * reactions.length)];
            r.style.left = (Math.random() * window.innerWidth) + 'px';
            r.style.top = (Math.random() * window.innerHeight) + 'px';
            r.style.fontSize = '4rem';
            document.body.appendChild(r);
            setTimeout(() => r.remove(), 1000);
          }, i * 100);
        }
      }
    } else { konamiIndex = 0; }
  });

  // --- Load data ---
  async function init() {
    try {
      const [sRes, hRes, dRes] = await Promise.all([
        fetch('services.json'),
        fetch('history.json'),
        fetch('deploy-stats.json').catch(() => null),
      ]);
      const services: Service[] = await sRes.json();
      const history: HistoryDay[] = await hRes.json();
      renderServices(services);
      setupFilters(services);
      renderHistory(history);
      if (dRes && dRes.ok) renderDeployCounter(await dRes.json());
    } catch (err) {
      console.error('Failed to load data:', err);
    }
  }

  init();

  // --- Mascot interactions ---
  const mascotSpeech = document.getElementById('mascot-speech');
  const mascot = document.getElementById('mascot');
  const mascotLines: Record<string, string[]> = {
    morning: ['おはよう！今日も頑張ろう！✨', 'いい朝だね～☀️', 'コーヒー飲んだ？☕'],
    afternoon: ['こんにちは！調子どう？🌤️', 'ランチ食べた？🍱', 'ファイト！がんばれ！💪'],
    evening: ['こんばんは～お疲れ様！💜', '今日もよく頑張った！🌙', '晩ごはんは何？🍽️'],
    night: ['まだ起きてるの？😮', 'そろそろ寝なよ～💤', '夜更かしはダメだよ！🦉'],
  };
  const lines = mascotLines[period] || mascotLines.night;
  let lineIdx = 0;

  if (mascot && mascotSpeech) {
    mascot.addEventListener('click', (e) => {
      e.stopPropagation();
      lineIdx = (lineIdx + 1) % lines.length;
      mascotSpeech.textContent = lines[lineIdx];
      mascotSpeech.style.opacity = '1';
      mascotSpeech.style.transform = 'translateX(-50%) translateY(-5px) scale(1)';
      setTimeout(() => {
        mascotSpeech.style.opacity = '0';
        mascotSpeech.style.transform = 'translateX(-50%) translateY(-5px) scale(0.8)';
      }, 3000);
      addCombo(e);
    });
  }
</script>
