---
import Base from '../layouts/Base.astro';
---

<Base title="홈" active="home">
  <!-- Greeting banner -->
  <div id="greeting" class="text-center py-3 px-5 mb-8 rounded-2xl bg-accent/8 border border-accent/15 text-lg font-bold text-text"></div>

  <!-- Filter pills -->
  <div class="flex justify-center gap-2 mb-6 flex-wrap" id="filters">
    <button class="filter-pill active" data-filter="all">전체</button>
    <button class="filter-pill" data-filter="infra">인프라</button>
    <button class="filter-pill" data-filter="media">미디어</button>
    <button class="filter-pill" data-filter="dev">개발</button>
  </div>

  <!-- Service cards grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-12" id="services"></div>

  <!-- History section -->
  <div class="mb-12">
    <h2 class="text-2xl font-black mb-6 text-text">작업 히스토리</h2>
    <div id="history"></div>
  </div>

  <!-- Footer: device status -->
  <footer class="flex justify-center gap-6 flex-wrap py-6 border-t border-border">
    <div class="flex items-center gap-2 text-sm font-bold text-sub">
      <span class="w-2 h-2 rounded-full bg-green shadow-[0_0_8px_var(--color-green)] animate-pulse"></span>
      NAS DS720+
    </div>
    <div class="flex items-center gap-2 text-sm font-bold text-sub">
      <span class="w-2 h-2 rounded-full bg-green shadow-[0_0_8px_var(--color-green)] animate-pulse"></span>
      Mac Studio
    </div>
    <div class="flex items-center gap-2 text-sm font-bold text-sub">
      <span class="w-2 h-2 rounded-full bg-green shadow-[0_0_8px_var(--color-green)] animate-pulse"></span>
      M1 mini
    </div>
    <div class="flex items-center gap-2 text-sm font-bold text-sub">
      <span class="w-2 h-2 rounded-full bg-green shadow-[0_0_8px_var(--color-green)] animate-pulse"></span>
      ER7206
    </div>
  </footer>
</Base>

<style is:inline>
  @keyframes card-in {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  // --- Greeting ---
  const greetings: Record<string, string[]> = {
    morning: ['おはよう、좋은 아침이야', '새로운 하루, 시작하자', '아침 커피 한 잔의 여유'],
    afternoon: ['こんにちは、오후도 힘내자', '점심 먹었어? 파이팅', '한낮의 집중 타임'],
    evening: ['おつかれ、오늘도 고생했어', '저녁 노을이 예쁜 시간', '하루 마무리, 잘 했어'],
    night: ['おやすみ、편한 밤 되길', '밤의 고요함 속에서', '오늘도 수고했어, 좋은 꿈'],
  };
  const h = new Date().getHours();
  const period = h >= 6 && h < 12 ? 'morning' : h < 17 ? 'afternoon' : h < 21 ? 'evening' : 'night';
  const msgs = greetings[period];
  const greetEl = document.getElementById('greeting');
  if (greetEl) greetEl.textContent = msgs[Math.floor(Math.random() * msgs.length)];

  // --- Types ---
  interface Service {
    name: string;
    domain: string;
    icon: string;
    description: string;
    route: string;
    category: string;
  }

  interface HistoryEntry {
    type: string;
    title: string;
    desc: string;
  }

  interface HistoryDay {
    date: string;
    entries: HistoryEntry[];
  }

  // --- Category colors ---
  const catColors: Record<string, { bg: string; text: string; iconBg: string }> = {
    infra: { bg: 'bg-orange/10', text: 'text-orange', iconBg: 'bg-orange/15' },
    media: { bg: 'bg-pink/10', text: 'text-pink', iconBg: 'bg-pink/15' },
    dev:   { bg: 'bg-blue/10', text: 'text-blue', iconBg: 'bg-blue/15' },
  };

  const catLabels: Record<string, string> = { infra: '인프라', media: '미디어', dev: '개발' };

  // --- Badge colors ---
  const badgeStyles: Record<string, { bg: string; text: string; label: string }> = {
    add:    { bg: 'bg-green/15', text: 'text-green', label: 'NEW' },
    fix:    { bg: 'bg-blue/15', text: 'text-blue', label: 'FIX' },
    remove: { bg: 'bg-red/15', text: 'text-red', label: 'DEL' },
    change: { bg: 'bg-orange/15', text: 'text-orange', label: 'CHG' },
  };

  // --- Gate token for Max/Claude ---
  const GATE_KEY = 'e3087205509900d6c862f806ccd58d1d';

  async function hmacToken(): Promise<string> {
    const enc = new TextEncoder();
    const ts = Math.floor(Date.now() / 30000).toString();
    const key = await crypto.subtle.importKey('raw', enc.encode(GATE_KEY), { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']);
    const sig = await crypto.subtle.sign('HMAC', key, enc.encode(ts));
    const token = Array.from(new Uint8Array(sig)).map(b => b.toString(16).padStart(2, '0')).join('').slice(0, 16);
    return `?t=${token}&ts=${ts}`;
  }

  // --- Render services ---
  function renderServices(services: Service[], filter = 'all') {
    const grid = document.getElementById('services');
    if (!grid) return;
    grid.innerHTML = '';
    const filtered = filter === 'all' ? services : services.filter(s => s.category === filter);

    filtered.forEach((s, i) => {
      const c = catColors[s.category] || catColors.infra;
      const proto = s.domain.startsWith('ftp.') ? 'ftp' : 'https';
      const href = s.domain.startsWith('ssh.') ? '#' : `${proto}://${s.domain}`;
      const isGated = s.domain.startsWith('max.') || s.domain.startsWith('claude.');

      const card = document.createElement('a');
      card.href = href;
      card.target = s.domain.startsWith('ssh.') ? '_self' : '_blank';
      card.rel = 'noopener';
      card.className = 'bg-card border border-border rounded-2xl p-6 block hover:border-accent/30 transition-all hover:-translate-y-1';
      card.style.animation = `card-in 0.4s ease ${i * 0.05}s both`;

      if (isGated) {
        card.dataset.gated = '1';
      }

      card.innerHTML = `
        <div class="flex items-center gap-4 mb-3">
          <div class="text-4xl w-14 h-14 flex items-center justify-center rounded-xl ${c.iconBg} shrink-0">${s.icon}</div>
          <div class="min-w-0">
            <div class="text-xl font-black text-text truncate">${s.name}</div>
            <div class="text-xs font-mono text-cyan truncate">${s.domain}</div>
          </div>
        </div>
        <p class="text-sub text-sm leading-relaxed mb-3">${s.description}</p>
        <div class="flex items-center justify-between">
          <span class="text-xs font-mono text-dim truncate max-w-[65%]">${s.route}</span>
          <span class="text-xs font-extrabold px-2.5 py-0.5 rounded-full ${c.bg} ${c.text}">${catLabels[s.category]}</span>
        </div>
      `;

      grid.appendChild(card);
    });
  }

  // --- Render history ---
  function renderHistory(days: HistoryDay[]) {
    const container = document.getElementById('history');
    if (!container) return;
    container.innerHTML = '';

    days.forEach(day => {
      const dayEl = document.createElement('div');
      dayEl.className = 'mb-6';

      const dateHeader = document.createElement('div');
      dateHeader.className = 'text-sm font-black text-gold mb-3 pl-3 border-l-3 border-gold';
      dateHeader.textContent = day.date;
      dayEl.appendChild(dateHeader);

      day.entries.forEach(entry => {
        const badge = badgeStyles[entry.type] || badgeStyles.change;
        const item = document.createElement('div');
        item.className = 'bg-card border border-border rounded-xl px-4 py-3 mb-2 flex items-start gap-3 hover:border-accent/20 transition-all hover:translate-x-1';
        item.innerHTML = `
          <span class="text-[0.65rem] font-extrabold px-2 py-0.5 rounded-full ${badge.bg} ${badge.text} shrink-0 mt-0.5">${badge.label}</span>
          <div class="min-w-0">
            <div class="text-sm font-bold text-text">${entry.title}</div>
            <div class="text-xs text-dim leading-relaxed">${entry.desc}</div>
          </div>
        `;
        dayEl.appendChild(item);
      });

      container.appendChild(dayEl);
    });
  }

  // --- Filter pills ---
  function setupFilters(services: Service[]) {
    document.querySelectorAll('.filter-pill').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-pill').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        renderServices(services, (btn as HTMLElement).dataset.filter || 'all');
      });
    });
  }

  // --- Gate click handler ---
  document.addEventListener('click', async (e) => {
    const a = (e.target as HTMLElement).closest('a[data-gated]');
    if (!a) return;
    e.preventDefault();
    const href = a.getAttribute('href');
    if (!href) return;
    const qs = await hmacToken();
    window.open(href + qs, '_blank');
  });

  // --- Load data ---
  async function init() {
    try {
      const [sRes, hRes] = await Promise.all([
        fetch('services.json'),
        fetch('history.json'),
      ]);
      const services: Service[] = await sRes.json();
      const history: HistoryDay[] = await hRes.json();
      renderServices(services);
      setupFilters(services);
      renderHistory(history);
    } catch (err) {
      console.error('Failed to load data:', err);
    }
  }

  init();
</script>

<style is:inline>
  .filter-pill {
    padding: 0.4rem 1rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    border: 1.5px solid transparent;
    background: var(--color-card);
    color: var(--color-sub);
    transition: all 0.2s;
  }
  .filter-pill:hover {
    background: var(--color-card-hover);
    color: var(--color-text);
  }
  .filter-pill.active {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
  }
</style>
